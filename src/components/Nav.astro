---
const navLinks = [
  { label: 'Corporate Training', href: '/corporate-training' },
  { label: 'POSH Training',      href: '/posh-training' },
  { label: 'LMS',                href: '/lms' },
  { label: 'Tools',              href: '/tools' },
  { label: 'Insights',           href: '/blog' },
  { label: 'About',              href: '/about' },
]

const currentPath = Astro.url.pathname
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="logo" aria-label="SnapSkill home">
      <img src="/logo.jpeg" alt="SnapSkill" class="logo-img" />
    </a>

    <nav class="nav-links" aria-label="Main navigation">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={['nav-link', { active: currentPath.startsWith(link.href) }]}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <a href="/contact" class="btn btn--primary nav-cta">Talk to us</a>

    <button class="hamburger" aria-label="Open menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<!-- Mobile nav drawer -->
<div class="mobile-drawer" id="mobileDrawer" aria-hidden="true">
  <nav>
    {navLinks.map(link => (
      <a href={link.href} class="mobile-link">{link.label}</a>
    ))}
    <a href="/contact" class="btn btn--primary mobile-cta">Talk to us</a>
  </nav>
</div>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255,255,255,0.97);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
  }

  .header-inner {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    height: 68px;
  }

  .logo {
    text-decoration: none;
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }
  .logo-img {
    height: 36px;
    width: auto;
    display: block;
    object-fit: contain;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--space-2xs);
    margin-left: auto;
  }

  .nav-link {
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-body);
    padding: 0.4em 0.65em;
    border-radius: var(--radius-sm);
    transition: var(--transition);
    text-decoration: none;
    white-space: nowrap;
  }
  .nav-link:hover,
  .nav-link.active {
    color: var(--color-primary);
    background: rgba(0,123,255,0.07);
    text-decoration: none;
  }

  /* POSH link gets a subtle teal tint to distinguish it */
  .nav-link[href="/posh-training"]:hover,
  .nav-link[href="/posh-training"].active {
    color: #007A6A;
    background: rgba(0,122,106,0.08);
  }

  .nav-cta { margin-left: var(--space-sm); font-size: 0.875rem; flex-shrink: 0; }

  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-xs);
    margin-left: auto;
  }
  .hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--color-dark);
    border-radius: 2px;
    transition: var(--transition);
  }

  /* Mobile drawer */
  .mobile-drawer {
    display: none;
    position: fixed;
    inset: 68px 0 0 0;
    background: white;
    z-index: 99;
    padding: var(--space-md);
    border-top: 1px solid var(--color-border);
    flex-direction: column;
    gap: var(--space-xs);
    overflow-y: auto;
  }
  .mobile-drawer.open { display: flex; }
  .mobile-link {
    font-family: var(--font-heading);
    font-size: 1rem; font-weight: 600;
    color: var(--color-dark);
    padding: var(--space-sm) var(--space-xs);
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
  }
  .mobile-link:hover { color: var(--color-primary); }
  .mobile-cta { margin-top: var(--space-sm); text-align: center; }

  @media (max-width: 900px) {
    .nav-links, .nav-cta { display: none; }
    .hamburger { display: flex; }
  }
</style>

<script>
  const hamburger = document.querySelector('.hamburger')
  const drawer    = document.getElementById('mobileDrawer')

  hamburger?.addEventListener('click', () => {
    const open = hamburger.getAttribute('aria-expanded') === 'true'
    hamburger.setAttribute('aria-expanded', String(!open))
    drawer?.classList.toggle('open', !open)
    drawer?.setAttribute('aria-hidden', String(open))
  })
</script>
