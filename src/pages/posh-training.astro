---
import BaseLayout from '../layouts/BaseLayout.astro'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'
---

<BaseLayout
  title="POSH Compliance Training — SafeWork"
  description="India's most engaging POSH Act training. Scenario-based, mobile-first, AI-coached — with admin dashboards and completion certificates. Built for enterprises serious about workplace safety."
>
  <Nav />
  <main>

  <!-- ═══════════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════════ -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true">
      <div class="bg-grid"></div>
      <div class="bg-orb bg-orb--1"></div>
      <div class="bg-orb bg-orb--2"></div>
    </div>
    <div class="container hero-inner">
      <div class="hero-text">
        <div class="hero-badge">
          <div class="badge-shield" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="white"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          SafeWork · POSH Compliance
        </div>
        <h1>POSH training your<br>employees will<br><span class="hero-hl">actually finish.</span></h1>
        <p class="hero-sub">Scenario-based, AI-coached, mobile-first POSH Act training — with admin dashboards, automated reminders, and verified completion certificates. Built for Indian enterprises.</p>
        <div class="hero-actions">
          <a href="/contact" class="btn btn--accent">Request a demo</a>
          <a href="#how-it-works" class="btn-ghost">See how it works →</a>
        </div>
        <div class="hero-trust">
          <div class="trust-item">
            <div class="trust-num">13</div>
            <div class="trust-label">Modules per course</div>
          </div>
          <div class="trust-sep" aria-hidden="true"></div>
          <div class="trust-item">
            <div class="trust-num">100%</div>
            <div class="trust-label">Mobile compatible</div>
          </div>
          <div class="trust-sep" aria-hidden="true"></div>
          <div class="trust-item">
            <div class="trust-num">POSH</div>
            <div class="trust-label">Act 2013 compliant</div>
          </div>
        </div>
      </div>

      <!-- Phone mockup trio -->
      <div class="hero-visual" aria-hidden="true">
        <div class="phone-trio">

          <!-- Back phone: module list -->
          <div class="phone phone--back">
            <div class="phone-shell">
              <div class="ph-notch"></div>
              <div class="ph-screen">
                <div class="ph-greeting">Namaste, Srinivas 👋</div>
                <div class="ph-date">Tuesday, 7 April</div>
                <div class="ph-progress-card">
                  <div class="ph-ring">
                    <svg viewBox="0 0 48 48" width="48" height="48">
                      <circle cx="24" cy="24" r="20" fill="none" stroke="rgba(255,255,255,0.15)" stroke-width="4"/>
                      <circle cx="24" cy="24" r="20" fill="none" stroke="white" stroke-width="4" stroke-dasharray="125.7" stroke-dashoffset="87" stroke-linecap="round" transform="rotate(-90 24 24)"/>
                    </svg>
                    <span>31%</span>
                  </div>
                  <div>
                    <div class="ph-prog-title">Your Progress</div>
                    <div class="ph-prog-sub">4 of 13 modules complete</div>
                  </div>
                </div>
                <div class="ph-continue">
                  <div class="ph-cont-label">Continue:</div>
                  <div class="ph-cont-title">Is This a Workplace?</div>
                </div>
                <div class="ph-modules">
                  <div class="ph-mod ph-mod--done">
                    <span class="ph-mod-badge done">Completed</span>
                    <div class="ph-mod-title">Setting the Stage</div>
                  </div>
                  <div class="ph-mod ph-mod--done">
                    <span class="ph-mod-badge done">Completed</span>
                    <div class="ph-mod-title">What Is Sexual Harassment?</div>
                  </div>
                  <div class="ph-mod ph-mod--active">
                    <span class="ph-mod-badge active">Module 5</span>
                    <div class="ph-mod-title">Is This a Workplace?</div>
                  </div>
                  <div class="ph-mod ph-mod--locked">
                    <span class="ph-mod-badge locked">Module 6</span>
                    <div class="ph-mod-title">The Reporting Roadmap</div>
                    <div class="ph-lock" aria-hidden="true">🔒</div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Front phone: AI chat -->
          <div class="phone phone--front">
            <div class="phone-shell">
              <div class="ph-notch"></div>
              <div class="ph-screen ph-screen--chat">
                <div class="ph-chat-header">
                  <div class="ph-chat-back">←</div>
                  <div>
                    <div class="ph-chat-title">SafeWork Coach</div>
                    <div class="ph-chat-sub">Module 3: The Grey Zone Game</div>
                  </div>
                </div>
                <div class="ph-chat-body">
                  <div class="chat-bubble chat-bubble--system">
                    Hello! Welcome to <strong>The Grey Zone Game.</strong> 👋
                    <br><br>
                    Workplace situations aren't always black and white. You tell me: is it Harassment, Not Harassment, or does it Depend?
                  </div>
                  <div class="chat-bubble chat-bubble--scenario">
                    <strong>Scenario 1:</strong><br>
                    Ravi tells Meena at a team lunch: 'You look really hot in that dress today.' Meena laughs awkwardly and changes the subject.
                  </div>
                  <div class="chat-bubble chat-bubble--user">Harassment</div>
                  <div class="chat-bubble chat-bubble--feedback">
                    <strong>Spot on.</strong> Calling a colleague 'hot' is a sexually coloured remark (Category 3).<br><br>
                    Intent (compliment) doesn't matter; impact (sexual remark) does.
                  </div>
                  <div class="chat-bubble chat-bubble--tip">
                    💡 Key takeaway: 'Hot' is not a professional compliment.
                  </div>
                </div>
                <div class="ph-chat-footer">Next Scenario →</div>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       THE PROBLEM
  ═══════════════════════════════════════════════ -->
  <section class="problem section">
    <div class="container problem-inner">
      <div class="problem-text">
        <p class="eyebrow-label">The Problem</p>
        <h2>Most POSH training is a checkbox exercise.<br>This one isn't.</h2>
        <p>The typical POSH training cycle: email all staff a PDF, wait for the "read receipt," file it away, repeat next year. Employees don't retain it. Managers can't enforce it. And the next incident still catches everyone off guard.</p>
        <p>The POSH Act requires meaningful training — not just documented exposure. SafeWork is built around what actually changes behaviour: scenario-based learning, real judgement calls, and AI-powered feedback that explains the why, not just the what.</p>
      </div>
      <div class="problem-vs">
        <div class="vs-col vs-col--bad">
          <h3>Typical POSH training</h3>
          <ul>
            <li>PDF or PowerPoint presentation</li>
            <li>No scenario or judgement practice</li>
            <li>Completed in 10 minutes, forgotten in 10 days</li>
            <li>No admin visibility on completion</li>
            <li>No evidence of understanding — just attendance</li>
          </ul>
        </div>
        <div class="vs-divider">vs</div>
        <div class="vs-col vs-col--good">
          <h3>SafeWork by SnapSkill</h3>
          <ul>
            <li>13-module structured learning journey</li>
            <li>AI coach with scenario-based practice</li>
            <li>Mobile-first — completes during commute</li>
            <li>Admin dashboard with real-time tracking</li>
            <li>Verified certificate per employee</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       HOW IT WORKS
  ═══════════════════════════════════════════════ -->
  <section class="how-it-works section section--tinted" id="how-it-works">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow-label">How It Works</p>
        <h2>A complete POSH training<br>system in one platform.</h2>
      </div>

      <div class="hiw-grid">

        <div class="hiw-card hiw-card--dark">
          <div class="hiw-visual" aria-hidden="true">
            <!-- Admin dashboard mini -->
            <div class="admin-mini">
              <div class="am-header">Admin Dashboard · POSH Training</div>
              <div class="am-stats">
                <div class="am-stat"><div class="am-num">247</div><div class="am-label">Enrolled</div></div>
                <div class="am-stat"><div class="am-num am-num--green">189</div><div class="am-label">Completed</div></div>
                <div class="am-stat"><div class="am-num am-num--yellow">41</div><div class="am-label">In Progress</div></div>
                <div class="am-stat"><div class="am-num am-num--red">17</div><div class="am-label">Not Started</div></div>
              </div>
              <div class="am-bar-label">Pass Rate</div>
              <div class="am-bar-wrap"><div class="am-bar" style="--w:84%"></div><span>84%</span></div>
              <div class="am-bar-label">Avg Completion</div>
              <div class="am-bar-wrap"><div class="am-bar am-bar--teal" style="--w:76%"></div><span>76%</span></div>
              <div class="am-footer">
                <div class="am-btn">Upload Employees CSV</div>
              </div>
            </div>
          </div>
          <div class="hiw-content">
            <div class="hiw-num">01</div>
            <h3>Upload your employee list</h3>
            <p>Add employees via CSV bulk upload or manual entry. Set a completion deadline, assign the course, and the system handles enrolment and reminder emails automatically.</p>
          </div>
        </div>

        <div class="hiw-card">
          <div class="hiw-visual hiw-visual--light" aria-hidden="true">
            <!-- Module journey mini -->
            <div class="journey-mini">
              <div class="jm-label">POSH Training — Course A</div>
              <div class="jm-modules">
                {[
                  { n:1, title:'Setting the Stage', status:'done', time:'5 min' },
                  { n:2, title:'What Is Sexual Harassment?', status:'done', time:'10 min' },
                  { n:3, title:'The Grey Zone Game', status:'done', time:'8 min' },
                  { n:4, title:'Your Workplace Is Bigger…', status:'done', time:'8 min' },
                  { n:5, title:'Is This a Workplace?', status:'active', time:'5 min' },
                  { n:6, title:'The Reporting Roadmap', status:'locked', time:'10 min' },
                ].map(m => (
                  <div class={`jm-mod jm-mod--${m.status}`}>
                    <div class="jm-icon">
                      {m.status === 'done' ? '✓' : m.status === 'active' ? '▶' : '🔒'}
                    </div>
                    <div class="jm-info">
                      <div class="jm-title">{m.title}</div>
                      <div class="jm-time">{m.time}</div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
          <div class="hiw-content">
            <div class="hiw-num hiw-num--dark">02</div>
            <h3>Employees learn at their own pace</h3>
            <p>13 structured modules covering the full POSH Act — definitions, categories, grey areas, reporting obligations, IC responsibilities, and real-world scenarios. Sequential gating ensures nothing is skipped.</p>
          </div>
        </div>

        <div class="hiw-card">
          <div class="hiw-visual hiw-visual--light" aria-hidden="true">
            <!-- Chat scenario mini -->
            <div class="chat-mini">
              <div class="cm-header">
                <div class="cm-title">SafeWork Coach</div>
                <div class="cm-sub">Module 3: The Grey Zone Game</div>
              </div>
              <div class="cm-body">
                <div class="cm-bubble cm-sys">Workplace situations aren't always black and white. Is it Harassment, Not Harassment, or does it Depend?</div>
                <div class="cm-scenario">
                  <strong>Scenario 2:</strong> A manager sends work emails at 11pm with passive-aggressive subject lines. The team feels unable to switch off.
                </div>
                <div class="cm-choices">
                  <div class="cm-choice">Harassment</div>
                  <div class="cm-choice cm-choice--selected">Depends</div>
                  <div class="cm-choice">Not Harassment</div>
                </div>
                <div class="cm-feedback cm-feedback--correct">
                  ✓ <strong>Correct.</strong> Repeated unreasonable behaviour that creates a hostile environment may constitute harassment under POSH if it targets an individual.
                </div>
              </div>
            </div>
          </div>
          <div class="hiw-content">
            <div class="hiw-num hiw-num--dark">03</div>
            <h3>AI coach makes it stick</h3>
            <p>The SafeWork Coach isn't just multiple choice — it's a conversational AI that presents real workplace scenarios, explains the legal reasoning behind each answer, and corrects misconceptions on the spot.</p>
          </div>
        </div>

        <div class="hiw-card hiw-card--accent">
          <div class="hiw-visual" aria-hidden="true">
            <!-- Certificate mini -->
            <div class="cert-mini">
              <div class="cert-shield">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="rgba(255,255,255,0.9)"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <div class="cert-text">
                <div class="cert-title">Certificate of Completion</div>
                <div class="cert-name">Priya Krishnamurthy</div>
                <div class="cert-course">POSH Compliance Training — SafeWork</div>
                <div class="cert-date">Completed 7 April 2026</div>
              </div>
              <div class="cert-verify">
                <div class="cert-qr-mini"></div>
                <div class="cert-verify-text">Verify online</div>
              </div>
            </div>
          </div>
          <div class="hiw-content">
            <div class="hiw-num">04</div>
            <h3>Verified certificates, automatically</h3>
            <p>When an employee completes all modules and passes the final assessment, a tamper-proof certificate is issued automatically — downloadable, shareable, and publicly verifiable via a unique code. Your HR records update in real time.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       MODULES
  ═══════════════════════════════════════════════ -->
  <section class="modules section">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow-label">The Curriculum</p>
        <h2>13 modules. Nothing skipped.</h2>
        <p>The SafeWork curriculum covers everything required under the POSH Act 2013 — from definitions and categories to reporting procedures, IC responsibilities, and bystander obligations.</p>
      </div>

      <div class="modules-grid">
        {[
          { n:'01', title:'Setting the Stage', desc:'Why POSH exists and what it means for your organisation.', time:'5 min' },
          { n:'02', title:'What Is Sexual Harassment?', desc:'Legal definitions, categories 1–3, and the intent vs impact distinction.', time:'10 min' },
          { n:'03', title:'The Grey Zone Game', desc:'AI-coached scenario practice: Harassment, Not Harassment, or Depends?', time:'8 min', ai:true },
          { n:'04', title:'Your Workplace Is Bigger Than You Think', desc:'How POSH applies beyond the office — client sites, travel, virtual meetings.', time:'8 min' },
          { n:'05', title:'Is This a Workplace?', desc:'Speed round: 8 workplace scenarios, test your knowledge.', time:'5 min', ai:true },
          { n:'06', title:'The Reporting Roadmap', desc:'How to make a complaint, what happens next, and employee protections.', time:'10 min' },
          { n:'07', title:'Help Priya Decide', desc:'An interactive scenario where you guide a colleague through a real situation.', time:'8 min', ai:true },
          { n:'08', title:'Bystander Power: The 5D Framework', desc:'Distract, Delegate, Document, Delay, Direct — how to intervene safely.', time:'8 min' },
          { n:'09', title:'What Would You Do?', desc:'Practice the bystander framework in simulated scenarios.', time:'6 min', ai:true },
          { n:'10', title:'Myths, Fears, and Facts', desc:'Common misconceptions about POSH — addressed directly and honestly.', time:'6 min' },
          { n:'11', title:'Sector Spotlight', desc:'Industry-specific scenarios relevant to your organisation\'s context.', time:'8 min' },
          { n:'12', title:'Final Assessment', desc:'Structured test covering all modules. Must pass to receive certificate.', time:'15 min' },
          { n:'13', title:'Your Reflection', desc:'A personal commitment module — what will you do differently?', time:'5 min' },
        ].map(m => (
          <div class="module-card">
            <div class="mod-num">{m.n}</div>
            <div class="mod-body">
              <div class="mod-title-row">
                <h3>{m.title}</h3>
                {m.ai && <span class="mod-ai-badge">AI Coach</span>}
              </div>
              <p>{m.desc}</p>
              <div class="mod-time">⏱ {m.time}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       COMPLIANCE CALLOUT
  ═══════════════════════════════════════════════ -->
  <section class="compliance section section--dark">
    <div class="container compliance-inner">
      <div class="compliance-text">
        <p class="eyebrow-label eyebrow--light">Legal Compliance</p>
        <h2 style="color:white">POSH Act compliance isn't optional.<br>Neither is meaningful training.</h2>
        <p style="color:rgba(255,255,255,0.65)">Under the Sexual Harassment of Women at Workplace (Prevention, Prohibition and Redressal) Act 2013, every organisation with 10 or more employees is required to conduct regular POSH awareness programmes. Failure to comply can result in penalties, loss of business licences, and significant reputational damage.</p>
        <p style="color:rgba(255,255,255,0.65)">SafeWork is designed to meet and exceed these requirements — with audit-ready completion records, IC training support, and verifiable employee certificates.</p>
        <a href="/contact" class="btn btn--accent" style="margin-top:var(--space-md)">Talk to us about rollout</a>
      </div>
      <div class="compliance-checklist">
        <h3 style="color:white;margin-bottom:var(--space-md)">What SafeWork covers</h3>
        {[
          'Definition of sexual harassment under POSH Act 2013',
          'All three categories of prohibited conduct',
          'Extended definition of workplace (including virtual)',
          'Complaint filing process and timelines',
          'Internal Committee (IC) roles and obligations',
          'Employee protections against retaliation',
          'Bystander intervention training',
          'Sector-specific scenario practice',
          'Final assessment + verifiable completion certificate',
        ].map(item => (
          <div class="checklist-item">
            <div class="cl-icon" aria-hidden="true">✓</div>
            <span>{item}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       FOR WHOM
  ═══════════════════════════════════════════════ -->
  <section class="for-whom section section--tinted">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow-label">Who It's For</p>
        <h2>Two courses. Every role covered.</h2>
      </div>
      <div class="courses-grid">
        <div class="course-card">
          <div class="course-tag">Course A</div>
          <h3>All Employees</h3>
          <p>Foundational POSH awareness for every person in your organisation — understanding the law, recognising harassment, knowing how to respond and report.</p>
          <ul class="course-list">
            <li>What counts as sexual harassment</li>
            <li>Your rights as an employee</li>
            <li>How to make a complaint</li>
            <li>Bystander responsibilities</li>
          </ul>
          <div class="course-meta">
            <span>13 modules</span>
            <span>~90 min total</span>
            <span>Final assessment</span>
          </div>
        </div>
        <div class="course-card course-card--featured">
          <div class="course-tag course-tag--accent">Course B</div>
          <h3>Managers & IC Members</h3>
          <p>Advanced training for Internal Committee members and people managers — covering investigation procedures, documentation, confidentiality obligations, and handling complaints properly.</p>
          <ul class="course-list">
            <li>IC formation and composition requirements</li>
            <li>Inquiry process and timelines</li>
            <li>Evidence handling and documentation</li>
            <li>Maintaining confidentiality</li>
            <li>Appeals and false complaint provisions</li>
          </ul>
          <div class="course-meta">
            <span>8 modules</span>
            <span>~60 min total</span>
            <span>Final assessment</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       LEAD MAGNET
  ═══════════════════════════════════════════════ -->
  <section class="section section--tinted">
    <div class="container">
      <div class="lm-card">
        <div class="lm-left">
          <p class="lm-eyebrow">Free Resource</p>
          <h3>POSH Compliance Audit Checklist</h3>
          <p>Is your organisation actually POSH-compliant — or just think it is? This 12-point checklist covers the most common gaps HR teams miss. Used by 100+ companies before their annual audits.</p>
          <ul class="lm-bullets">
            <li>Internal Committee formation requirements</li>
            <li>Annual report obligations (Section 21)</li>
            <li>Training documentation and completion records</li>
            <li>Policy display and employee awareness requirements</li>
          </ul>
        </div>
        <div class="lm-right">
          <p class="lm-how">How to get it</p>
          <ol class="lm-steps">
            <li>Tap the button below</li>
            <li>WhatsApp opens with a ready-to-send message</li>
            <li>Hit send — we'll reply with the checklist</li>
          </ol>
          <a href="https://wa.me/919876656573?text=Hi%21+Send+me+the+POSH+Compliance+Checklist" target="_blank" rel="noopener" class="btn lm-wa-btn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp us for the free checklist
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       CTA
  ═══════════════════════════════════════════════ -->
  <section class="final-cta">
    <div class="fcta-bg" aria-hidden="true">
      <div class="fcta-orb fcta-orb--1"></div>
      <div class="fcta-orb fcta-orb--2"></div>
    </div>
    <div class="container fcta-inner">
      <div class="fcta-shield" aria-hidden="true">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="rgba(255,195,0,0.8)"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
      </div>
      <h2>Make your POSH compliance<br>count for something.</h2>
      <p>Book a 20-minute demo — we'll show you the employee experience, the admin dashboard, and how rollout works for your team size.</p>
      <div class="fcta-actions">
        <a href="https://wa.me/919876656573?text=Hi%21+I%27d+like+to+see+a+demo+of+SafeWork+POSH+Training." target="_blank" rel="noopener" class="btn btn--accent fcta-wa-btn">
