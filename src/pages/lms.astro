---
import BaseLayout from '../layouts/BaseLayout.astro'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'
---

<BaseLayout
  title="SnapSkill LMS — AI-Powered Learning Platform for Enterprise"
  description="The complete learning platform for enterprise AI upskilling. Tests, courses, live sessions, certificates and analytics — all in one place."
>
  <Nav />
  <main>

  <!-- ═══════════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════════ -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true">
      <div class="bg-grid"></div>
      <div class="bg-orb bg-orb--1"></div>
      <div class="bg-orb bg-orb--2"></div>
    </div>

    <div class="container hero-inner">
      <div class="hero-text">
        <div class="hero-eyebrow">
          <span class="live-dot" aria-hidden="true"></span>
          Enterprise Learning Platform
        </div>
        <h1>The complete LMS<br>your team will<br><span class="hero-highlight">actually use.</span></h1>
        <p class="hero-sub">Tests, courses, live sessions, certificates, and analytics — built for serious AI upskilling at enterprise scale. Multi-tenant, SSO-ready, mobile-first.</p>
        <div class="hero-actions">
          <a href="/contact" class="btn btn--primary">Request a demo</a>
          <a href="/corporate-training" class="btn-ghost">See training programs →</a>
        </div>
        <div class="hero-trust">
          <div class="trust-item">
            <span class="trust-num">2,000+</span>
            <span class="trust-label">Learners</span>
          </div>
          <div class="trust-sep" aria-hidden="true"></div>
          <div class="trust-item">
            <span class="trust-num">15+</span>
            <span class="trust-label">Organisations</span>
          </div>
          <div class="trust-sep" aria-hidden="true"></div>
          <div class="trust-item">
            <span class="trust-num">92%</span>
            <span class="trust-label">Satisfaction</span>
          </div>
        </div>
      </div>

      <!-- Animated dashboard mockup -->
      <div class="hero-visual" aria-hidden="true">
        <div class="dashboard">
          <div class="dash-topbar">
            <div class="dash-logo-dot"></div>
            <div class="dash-title">SnapSkill Admin</div>
            <div class="dash-notif">
              <div class="notif-dot"></div>
            </div>
          </div>

          <div class="dash-body">
            <div class="dash-sidebar">
              <div class="sbl active">Dashboard</div>
              <div class="sbl">Tests</div>
              <div class="sbl">Courses</div>
              <div class="sbl">Students</div>
              <div class="sbl">Analytics</div>
              <div class="sbl">Live</div>
            </div>

            <div class="dash-main">
              <!-- Stat cards -->
              <div class="dash-stats">
                <div class="dstat">
                  <div class="dstat-label">Learners</div>
                  <div class="dstat-num count-up" data-target="847">0</div>
                  <div class="dstat-delta up">+12 this week</div>
                </div>
                <div class="dstat">
                  <div class="dstat-label">Avg Score</div>
                  <div class="dstat-num count-up" data-target="78">0</div><span class="dstat-unit">%</span>
                  <div class="dstat-delta up">+3.2 pts</div>
                </div>
                <div class="dstat">
                  <div class="dstat-label">Completion</div>
                  <div class="dstat-num count-up" data-target="91">0</div><span class="dstat-unit">%</span>
                  <div class="dstat-delta up">On track</div>
                </div>
              </div>

              <!-- Progress bars -->
              <div class="dash-section-label">Active Cohorts</div>
              <div class="dash-courses">
                <div class="dc-row">
                  <span class="dc-name">AI Fundamentals</span>
                  <div class="dc-bar"><div class="dc-fill" style="--w:82%"></div></div>
                  <span class="dc-pct">82%</span>
                </div>
                <div class="dc-row">
                  <span class="dc-name">Prompt Engineering</span>
                  <div class="dc-bar"><div class="dc-fill" style="--w:61%"></div></div>
                  <span class="dc-pct">61%</span>
                </div>
                <div class="dc-row">
                  <span class="dc-name">AI for Managers</span>
                  <div class="dc-bar"><div class="dc-fill" style="--w:44%"></div></div>
                  <span class="dc-pct">44%</span>
                </div>
              </div>

              <!-- Live activity feed -->
              <div class="dash-section-label">Live Activity</div>
              <div class="dash-feed">
                <div class="feed-item feed-item--1">
                  <div class="feed-dot green"></div>
                  <span>Priya M. completed <b>Module 3</b></span>
                  <span class="feed-time">just now</span>
                </div>
                <div class="feed-item feed-item--2">
                  <div class="feed-dot blue"></div>
                  <span>Rahul K. started <b>AI Fundamentals</b></span>
                  <span class="feed-time">2m ago</span>
                </div>
                <div class="feed-item feed-item--3">
                  <div class="feed-dot yellow"></div>
                  <span>Certificate issued to <b>Ananya S.</b></span>
                  <span class="feed-time">5m ago</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Floating badges -->
        <div class="float-badge float-badge--tl">
          <div class="fb-icon green-circle"></div>
          <div>
            <div class="fb-title">Test submitted</div>
            <div class="fb-sub">Score: 86% · Passed</div>
          </div>
        </div>
        <div class="float-badge float-badge--br">
          <div class="fb-icon blue-circle"></div>
          <div>
            <div class="fb-title">Certificate issued</div>
            <div class="fb-sub">AI Fundamentals</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       LIFECYCLE FLOW
  ═══════════════════════════════════════════════ -->
  <section class="lifecycle">
    <div class="container">
      <div class="lc-header">
        <p class="eyebrow-label">One platform</p>
        <h2>The complete learning lifecycle,<br>without the integration headaches.</h2>
      </div>

      <div class="lc-flow" aria-label="Platform flow diagram">
        {[
          { step: '01', label: 'Enrol',     desc: 'Add students via CSV, manual entry, SSO, or self-registration with custom approval workflows.' },
          { step: '02', label: 'Assign',    desc: 'Assign tests and courses with due dates, access codes, and attempt limits.' },
          { step: '03', label: 'Learn',     desc: 'Students access lessons (video, PDF, HTML), live Zoom sessions, and proctored tests.' },
          { step: '04', label: 'Assess',    desc: 'Configurable tests: shuffled questions, negative marking, multi-section, timed or windowed.' },
          { step: '05', label: 'Analyse',   desc: 'Score distributions, question difficulty, cohort comparisons, and completion rates.' },
          { step: '06', label: 'Certify',   desc: 'Auto-issue branded certificates with public verification codes.' },
        ].map((s, i) => (
          <div class="lc-step">
            <div class="lc-node">
              <div class="lc-num">{s.step}</div>
            </div>
            {i < 5 && <div class="lc-connector" aria-hidden="true"><div class="lc-flow-line"></div></div>}
            <div class="lc-label">{s.label}</div>
            <div class="lc-desc">{s.desc}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       FEATURES — THREE COLUMNS
  ═══════════════════════════════════════════════ -->
  <section class="features section">
    <div class="container">
      <div class="feat-header">
        <p class="eyebrow-label">Platform Capabilities</p>
        <h2>Everything in one platform.<br>Nothing bolted on.</h2>
      </div>

      <div class="feat-grid">

        <!-- Test Engine -->
        <div class="feat-card feat-card--dark">
          <div class="feat-visual" aria-hidden="true">
            <!-- Animated question palette -->
            <div class="palette-demo">
              <div class="pd-label">Question Palette</div>
              <div class="pd-grid">
                {Array.from({length: 20}, (_, i) => (
                  <div class={`pd-q ${
                    [2,5,8,11,14,17].includes(i) ? 'answered' :
                    [3,9,15].includes(i) ? 'flagged' :
                    i === 6 ? 'current' : 'unanswered'
                  }`}>{i+1}</div>
                ))}
              </div>
              <div class="pd-legend">
                <span class="leg answered">Answered</span>
                <span class="leg flagged">Flagged</span>
                <span class="leg current">Current</span>
              </div>
            </div>
            <div class="timer-pill">
              <div class="timer-ring" aria-hidden="true"></div>
              <span class="timer-text">24:37</span>
            </div>
          </div>
          <h3>Powerful Test Engine</h3>
          <p>Timed or windowed tests, multi-section, shuffled questions and options, negative marking, partial scoring, and auto-submit on expiry.</p>
          <ul class="feat-list">
            <li>Access code protection</li>
            <li>Anti-tab switching detection</li>
            <li>Auto-save every 30 seconds</li>
            <li>Resume on browser refresh</li>
          </ul>
        </div>

        <!-- Course Builder -->
        <div class="feat-card">
          <div class="feat-visual feat-visual--light" aria-hidden="true">
            <div class="course-builder">
              <div class="cb-item cb-item--done">
                <div class="cb-check"></div>
                <span>Introduction to AI</span>
                <span class="cb-type">Video</span>
              </div>
              <div class="cb-item cb-item--done">
                <div class="cb-check"></div>
                <span>Core Concepts</span>
                <span class="cb-type">PDF</span>
              </div>
              <div class="cb-item cb-item--active">
                <div class="cb-dot"></div>
                <span>Hands-on Exercises</span>
                <span class="cb-type">HTML</span>
              </div>
              <div class="cb-item">
                <div class="cb-empty"></div>
                <span>Final Assessment</span>
                <span class="cb-type">Test</span>
              </div>
              <div class="cb-item">
                <div class="cb-empty"></div>
                <span>Certification</span>
                <span class="cb-type">Cert</span>
              </div>
              <div class="cb-progress">
                <div class="cbp-bar"><div class="cbp-fill"></div></div>
                <span>60% complete</span>
              </div>
            </div>
          </div>
          <h3>Structured Course Builder</h3>
          <p>Mix lessons (video, PDF, HTML), embedded tests, and live sessions into sequenced learning paths with completion gating.</p>
          <ul class="feat-list">
            <li>YouTube, Vimeo, S3 video support</li>
            <li>Rich HTML lesson editor</li>
            <li>Due dates and progress tracking</li>
            <li>Duplicate and reuse courses</li>
          </ul>
        </div>

        <!-- Live Sessions -->
        <div class="feat-card">
          <div class="feat-visual feat-visual--light" aria-hidden="true">
            <div class="live-session">
              <div class="ls-header">
                <div class="ls-live-badge">
                  <span class="ls-live-dot"></span>LIVE
                </div>
                <span class="ls-title">AI Strategy Workshop</span>
              </div>
              <div class="ls-participants">
                <div class="ls-avatars">
                  {['P','R','A','S','K'].map(l => <div class="ls-av">{l}</div>)}
                  <div class="ls-av ls-av--more">+18</div>
                </div>
                <span class="ls-count">23 attendees</span>
              </div>
              <div class="ls-bar">
                <div class="ls-fill"></div>
              </div>
              <div class="ls-meta">Started 14 minutes ago · Zoom</div>
              <div class="ls-actions">
                <div class="ls-btn ls-btn--join">Join as Host</div>
                <div class="ls-btn ls-btn--view">View Attendance</div>
              </div>
            </div>
          </div>
          <h3>Zoom Live Sessions</h3>
          <p>Schedule and run Zoom sessions inside the platform. Auto-track attendance, download recordings, and turn sessions into lessons automatically.</p>
          <ul class="feat-list">
            <li>OAuth Zoom integration</li>
            <li>Webhook-based attendance tracking</li>
            <li>Auto recording → S3 → Lesson</li>
            <li>Student join links in-platform</li>
          </ul>
        </div>

        <!-- Analytics -->
        <div class="feat-card feat-card--accent">
          <div class="feat-visual" aria-hidden="true">
            <div class="analytics-demo">
              <div class="ad-label">Score Distribution</div>
              <div class="ad-bars">
                {[
                  {h:20, label:'0-40'},
                  {h:35, label:'41-50'},
                  {h:65, label:'51-60'},
                  {h:90, label:'61-70'},
                  {h:100, label:'71-80'},
                  {h:75, label:'81-90'},
                  {h:45, label:'91-100'},
                ].map(b => (
                  <div class="ad-col">
                    <div class="ad-bar" style={`--bh:${b.h}%`}></div>
                    <div class="ad-blabel">{b.label}</div>
                  </div>
                ))}
              </div>
              <div class="ad-stats">
                <div class="ad-stat"><span>Avg</span><strong>72%</strong></div>
                <div class="ad-stat"><span>Pass rate</span><strong>84%</strong></div>
                <div class="ad-stat"><span>Difficulty</span><strong>Medium</strong></div>
              </div>
            </div>
          </div>
          <h3>Deep Analytics</h3>
          <p>Score distributions, question-level difficulty analysis, cohort comparisons, and item-by-item completion breakdowns for courses.</p>
          <ul class="feat-list">
            <li>Per-question difficulty scoring</li>
            <li>Section-wise performance</li>
            <li>Export results as CSV</li>
            <li>Course completion funnels</li>
          </ul>
        </div>

        <!-- Certificates -->
        <div class="feat-card">
          <div class="feat-visual feat-visual--light" aria-hidden="true">
            <div class="cert-demo">
              <div class="cert-border">
                <div class="cert-logo-row">
                  <div class="cert-logo-box"></div>
                </div>
                <div class="cert-title-line">Certificate of Completion</div>
                <div class="cert-name-line">Ananya Sharma</div>
                <div class="cert-course-line">AI Fundamentals Program</div>
                <div class="cert-footer-row">
                  <div class="cert-sig">
                    <div class="cert-sig-line"></div>
                    <div class="cert-sig-label">Authorised Signatory</div>
                  </div>
                  <div class="cert-qr">
                    <div class="cert-qr-inner">
                      <div class="qr-grid">
                        {Array.from({length: 16}).map(() => <div class="qr-cell"></div>)}
                      </div>
                    </div>
                    <div class="cert-verify">Verify online</div>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <h3>Branded Certificates</h3>
          <p>Auto-issue certificates on test pass or course completion. Customise with your logo, colours, and signatory. Every cert has a unique public verification code.</p>
          <ul class="feat-list">
            <li>Auto-generated on completion</li>
            <li>Public verification URL</li>
            <li>Downloadable & shareable</li>
            <li>Custom template per test/course</li>
          </ul>
        </div>

        <!-- Multi-tenancy & Security -->
        <div class="feat-card feat-card--dark">
          <div class="feat-visual" aria-hidden="true">
            <div class="multitenancy-demo">
              <div class="mt-cloud">
                <div class="mt-platform-label">SnapSkill LMS</div>
                <div class="mt-nodes">
                  <div class="mt-node">
                    <div class="mt-node-inner">
                      <div class="mt-org-dot" style="background:#007BFF"></div>
                      <span>Acme Corp</span>
                    </div>
                    <div class="mt-node-sub">340 learners</div>
                  </div>
                  <div class="mt-node">
                    <div class="mt-node-inner">
                      <div class="mt-org-dot" style="background:#FFC300"></div>
                      <span>TechCo</span>
                    </div>
                    <div class="mt-node-sub">128 learners</div>
                  </div>
                  <div class="mt-node">
                    <div class="mt-node-inner">
                      <div class="mt-org-dot" style="background:#10b981"></div>
                      <span>FinBank</span>
                    </div>
                    <div class="mt-node-sub">589 learners</div>
                  </div>
                </div>
                <div class="mt-security-row">
                  <div class="mt-badge">JWT · HTTP-only Cookies</div>
                  <div class="mt-badge">Google & MS SSO</div>
                  <div class="mt-badge">Data isolation</div>
                </div>
              </div>
            </div>
          </div>
          <h3>Multi-Tenant & Secure</h3>
          <p>Every organisation gets its own isolated environment, custom branding, and SSO config. Built on strict multi-tenancy — no data leaks between orgs.</p>
          <ul class="feat-list">
            <li>Org-level branding & custom domain</li>
            <li>Google & Microsoft SSO per org</li>
            <li>Role-based access (Super Admin / Org Admin / Student)</li>
            <li>JWT with HTTP-only cookies</li>
          </ul>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       STUDENT EXPERIENCE CALLOUT
  ═══════════════════════════════════════════════ -->
  <section class="student-exp section section--tinted">
    <div class="container se-inner">
      <div class="se-text">
        <p class="eyebrow-label">Student Experience</p>
        <h2>Tests students don't dread.<br>Courses they actually finish.</h2>
        <p>The student interface is fast, mobile-first, and designed to get out of the way. Learners see only what they're assigned, with clear status, deadlines, and next steps.</p>
        <ul class="se-list">
          <li>
            <div class="se-check" aria-hidden="true"></div>
            <div>
              <strong>Resumable tests</strong>
              <p>Browser refresh or network drop? Answers auto-save every 30 seconds. Students resume exactly where they left off.</p>
            </div>
          </li>
          <li>
            <div class="se-check" aria-hidden="true"></div>
            <div>
              <strong>Mobile-first test taking</strong>
              <p>Question palette, timer, and submit — all accessible on a phone or tablet without pinch-zooming or horizontal scrolling.</p>
            </div>
          </li>
          <li>
            <div class="se-check" aria-hidden="true"></div>
            <div>
              <strong>Rich result feedback</strong>
              <p>Admin-configurable: show score only, or reveal correct answers with explanations per question.</p>
            </div>
          </li>
        </ul>
      </div>
      <div class="se-visual" aria-hidden="true">
        <!-- Mobile test-taking mockup -->
        <div class="phone-mockup">
          <div class="phone-shell">
            <div class="phone-notch"></div>
            <div class="phone-screen">
              <div class="ph-header">
                <span class="ph-test-name">AI Fundamentals · Q7</span>
                <div class="ph-timer">18:42</div>
              </div>
              <div class="ph-question">
                Which technique improves LLM output quality by providing examples in the prompt?
              </div>
              <div class="ph-options">
                <div class="ph-opt">Fine-tuning</div>
                <div class="ph-opt ph-opt--selected">Few-shot prompting</div>
                <div class="ph-opt">RLHF</div>
                <div class="ph-opt">RAG</div>
              </div>
              <div class="ph-nav">
                <div class="ph-btn">← Prev</div>
                <div class="ph-palette-mini">
                  {Array.from({length: 12}, (_, i) => (
                    <div class={`ph-q ${[0,1,3,5,6].includes(i) ? 'ph-q--ans' : i===6 ? 'ph-q--cur' : ''}`}></div>
                  ))}
                </div>
                <div class="ph-btn ph-btn--next">Next →</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       ADMIN POWER FEATURES
  ═══════════════════════════════════════════════ -->
  <section class="admin-features section">
    <div class="container">
      <div class="feat-header">
        <p class="eyebrow-label">For Administrators</p>
        <h2>Control without complexity.</h2>
      </div>
      <div class="admin-grid">
        {[
          { title: 'Question Bank', desc: 'Build and curate questions with images, multiple correct answers, and per-question scoring overrides. Draft → Active → Archived workflow keeps your bank clean.' },
          { title: 'Custom Student Fields', desc: 'Define custom fields (text, number, date, dropdown) that appear in registration forms and student profiles. Required or optional, ordered as you like.' },
          { title: 'Bulk Operations', desc: 'Import students via CSV, bulk-assign tests, export results with one click. Template downloads make bulk ops foolproof.' },
          { title: 'Access Code Control', desc: 'Generate unique access codes per assignment. View masked, reveal on click, export as CSV, or regenerate individual codes.' },
          { title: 'Announcement System', desc: 'Send targeted announcements to all students or specific groups. Schedule for later, set expiry dates, publish or unpublish on demand.' },
          { title: 'Pending Approvals', desc: 'Require admin approval for self-registered students. Review, approve, or reject with one click. Auto-approve also available.' },
        ].map(f => (
          <div class="admin-card">
            <div class="admin-card-bar" aria-hidden="true"></div>
            <h3>{f.title}</h3>
            <p>{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       PRICING
  ═══════════════════════════════════════════════ -->
  <section class="pricing section section--tinted">
    <div class="container">
      <div class="feat-header">
        <p class="eyebrow-label">Pricing</p>
        <h2>Simple, transparent pricing.</h2>
        <p class="feat-sub">All plans include onboarding support and a dedicated customer success contact.</p>
      </div>
      <div class="pricing-grid">
        <div class="plan">
          <div class="plan-name">Starter</div>
          <div class="plan-price">₹99<span>/learner/mo</span></div>
          <p class="plan-desc">For teams getting started with structured AI upskilling.</p>
          <ul>
            <li>Up to 500 learners</li>
            <li>3 pre-built learning paths</li>
            <li>Tests + Courses</li>
            <li>Basic analytics</li>
            <li>Email support</li>
          </ul>
          <a href="/contact" class="plan-btn">Get started</a>
        </div>
        <div class="plan plan--featured">
          <div class="plan-featured-tag">Most Popular</div>
          <div class="plan-name">Growth</div>
          <div class="plan-price">₹75<span>/learner/mo</span></div>
          <p class="plan-desc">For organisations running cohort programs at scale.</p>
          <ul>
            <li>Above 500 learners</li>
            <li>All learning paths + custom content</li>
            <li>Live sessions (Zoom)</li>
            <li>Certificates + verification</li>
            <li>HRMS integration & SSO</li>
            <li>Manager dashboards</li>
            <li>Dedicated CSM</li>
          </ul>
          <a href="/contact" class="plan-btn plan-btn--accent">Get started</a>
        </div>
        <div class="plan">
          <div class="plan-name">Enterprise</div>
          <div class="plan-price">Custom</div>
          <p class="plan-desc">For large organisations with complex requirements.</p>
          <ul>
            <li>Unlimited learners</li>
            <li>Custom branding & domain</li>
            <li>On-premise option</li>
            <li>S3 + CloudFront integration</li>
            <li>SLA-backed support</li>
            <li>Dedicated implementation team</li>
          </ul>
          <a href="/contact" class="plan-btn">Talk to us</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       LEAD MAGNET
  ═══════════════════════════════════════════════ -->
  <section class="section section--tinted">
    <div class="container">
      <div class="lm-card">
        <div class="lm-left">
          <p class="lm-eyebrow">Free Resource</p>
          <h3>LMS Evaluation Template</h3>
          <p>A ready-made spreadsheet to compare LMS platforms objectively — covering content types, analytics, integrations, pricing structure, and support. Built from 50+ platform evaluations.</p>
          <ul class="lm-bullets">
            <li>20+ criteria across learning experience, admin, and cost</li>
            <li>Side-by-side scoring columns for each vendor</li>
            <li>Notes column with what to ask on each vendor call</li>
          </ul>
        </div>
        <div class="lm-right">
          <p class="lm-how">How to get it</p>
          <ol class="lm-steps">
            <li>Tap the button below</li>
