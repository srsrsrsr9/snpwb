/* ─── Lifecycle Flow ────────────────────────────── */
.lifecycle {
  padding: var(--space-2xl) 0;
  border-bottom: 1px solid var(--color-border);
}
.lc-header { text-align: center; margin-bottom: var(--space-xl); }
.lc-header h2 { margin: var(--space-xs) 0; }

.lc-flow {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 0;
  position: relative;
}
.lc-step { display: flex; flex-direction: column; align-items: center; text-align: center; position: relative; }
.lc-node { position: relative; margin-bottom: var(--space-sm); }
.lc-num {
  width: 52px; height: 52px;
  border-radius: 50%;
  background: var(--color-primary);
  color: white;
  font-family: var(--font-heading);
  font-size: 0.85rem;
  font-weight: 700;
  display: flex; align-items: center; justify-content: center;
  position: relative; z-index: 1;
  box-shadow: 0 0 0 6px rgba(0,123,255,0.12);
  transition: var(--transition);
}
.lc-step:hover .lc-num { transform: scale(1.1); box-shadow: 0 0 0 10px rgba(0,123,255,0.15); }
.lc-connector {
  position: absolute;
  top: 26px;
  left: 50%;
  width: 100%;
  height: 2px;
  z-index: 0;
}
.lc-flow-line {
  width: 100%;
  height: 2px;
  background: linear-gradient(90deg, var(--color-primary), rgba(0,123,255,0.3));
  position: relative;
  overflow: hidden;
}
.lc-flow-line::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, transparent, white, transparent);
  animation: flowShimmer 2s linear infinite;
}
@keyframes flowShimmer {
  from { transform: translateX(-100%); }
  to   { transform: translateX(200%); }
}
.lc-label { font-family: var(--font-heading); font-size: 1rem; font-weight: 700; color: var(--color-dark); margin-bottom: var(--space-xs); }
.lc-desc  { font-size: 0.8rem; color: var(--color-body); padding: 0 var(--space-xs); line-height: 1.5; max-width: 140px; }

