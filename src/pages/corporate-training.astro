---
import BaseLayout from '../layouts/BaseLayout.astro'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'
---

<BaseLayout
  title="Corporate AI Training Programs"
  description="Custom AI training for enterprise teams. Built around your tools, your workflows, and your people — not generic slides."
>
  <Nav />
  <main>

  <!-- Hero -->
  <section class="ct-hero">
    <div class="container">
      <div class="hero-inner">
        <div class="hero-text">
          <p class="badge badge--accent">Corporate Training</p>
          <h1>AI training that fits<br>your <span class="text-primary">actual business.</span></h1>
          <p class="hero-sub">Off-the-shelf AI courses teach generic skills. We design programs around your team's real tools, real data, and real workflows — so learning translates into output from week one.</p>
          <div class="hero-actions">
            <a href="/contact" class="btn btn--primary">Talk to us about your team</a>
            <a href="/lms" class="btn btn--outline">Explore our LMS</a>
          </div>
        </div>
        <!-- Animated training dashboard visual -->
        <div class="hero-visual" aria-hidden="true">
          <div class="training-dash">
            <div class="td-topbar">
              <div class="td-logo-dot"></div>
              <div class="td-title">Training Dashboard</div>
              <div class="td-live"><span class="td-live-dot"></span>Live</div>
            </div>
            <div class="td-body">
              <div class="td-stats">
                <div class="tds"><div class="tds-num">2,000<span>+</span></div><div class="tds-label">Trained</div></div>
                <div class="tds"><div class="tds-num">92<span>%</span></div><div class="tds-label">Satisfaction</div></div>
                <div class="tds"><div class="tds-num">3<span>wk</span></div><div class="tds-label">To first cohort</div></div>
              </div>
              <div class="td-section-label">Active Programs</div>
              <div class="td-cohorts">
                <div class="tdc-row"><div class="tdc-dot" style="background:#007BFF"></div><span class="tdc-name">AI for Executives</span><div class="tdc-bar"><div class="tdc-fill" style="--w:100%"></div></div><span class="tdc-pct">Done</span></div>
                <div class="tdc-row"><div class="tdc-dot" style="background:#FFC300"></div><span class="tdc-name">AI-Enabled Management</span><div class="tdc-bar"><div class="tdc-fill" style="--w:67%"></div></div><span class="tdc-pct">67%</span></div>
                <div class="tdc-row"><div class="tdc-dot" style="background:#10b981"></div><span class="tdc-name">AI Skills Bootcamp</span><div class="tdc-bar"><div class="tdc-fill" style="--w:38%"></div></div><span class="tdc-pct">38%</span></div>
              </div>
              <div class="td-section-label">Skill Lift · Week 6 vs Baseline</div>
              <div class="td-lift">
                <div class="tdl-row"><span>Prompt Engineering</span><div class="tdl-bars"><div class="tdl-before" style="--bw:28%"></div><div class="tdl-after" style="--aw:84%"></div></div><span class="tdl-delta">+56pts</span></div>
                <div class="tdl-row"><span>AI Tool Proficiency</span><div class="tdl-bars"><div class="tdl-before" style="--bw:21%"></div><div class="tdl-after" style="--aw:79%"></div></div><span class="tdl-delta">+58pts</span></div>
                <div class="tdl-row"><span>Workflow Automation</span><div class="tdl-bars"><div class="tdl-before" style="--bw:15%"></div><div class="tdl-after" style="--aw:71%"></div></div><span class="tdl-delta">+56pts</span></div>
                <div class="tdl-legend"><span class="tdl-leg tdl-leg--before">Baseline</span><span class="tdl-leg tdl-leg--after">Week 6</span></div>
              </div>
              <div class="td-feed">
                <div class="tdf-item tdf-item--1"><div class="tdf-dot green"></div><span>Ananya S. passed final assessment · <b>88%</b></span></div>
                <div class="tdf-item tdf-item--2"><div class="tdf-dot blue"></div><span>Week 4 session completed · <b>23 attendees</b></span></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- The problem -->
  <section class="problem section section--tinted">
    <div class="container problem-inner">
      <div class="problem-text">
        <p class="badge">The Problem</p>
        <h2>Generic AI training doesn't stick.</h2>
        <p>Your team sits through a two-day workshop on "AI fundamentals." They learn what a large language model is. They go back to their desks and nothing changes.</p>
        <p>The issue isn't motivation — it's relevance. When training isn't connected to real tasks, real tools, and real workflows, it evaporates within weeks.</p>
        <p>We build programs the other way around: starting with what your team actually does, then designing AI skills that make them measurably better at it.</p>
      </div>
      <div class="problem-vs">
        <div class="vs-col vs-col--bad">
          <h3>Generic training</h3>
          <ul>
            <li>One-size-fits-all curriculum</li>
            <li>Theoretical examples only</li>
            <li>No connection to your tools</li>
            <li>Forgotten in 2 weeks</li>
            <li>No behaviour change measurement</li>
          </ul>
        </div>
        <div class="vs-divider">vs</div>
        <div class="vs-col vs-col--good">
          <h3>SnapSkill approach</h3>
          <ul>
            <li>Built around your actual workflows</li>
            <li>Your data, your tools, your scenarios</li>
            <li>Role-specific skill tracks</li>
            <li>Reinforced over 4–8 weeks</li>
            <li>Output-based completion criteria</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Programs -->
  <section class="programs section">
    <div class="container">
      <div class="section-header">
        <p class="badge">Our Programs</p>
        <h2>Training for every layer<br>of your organisation.</h2>
      </div>

      <div class="programs-grid">
        {[
          {
            tag: 'For Leadership',
            title: 'AI for Executives',
            duration: '1 day intensive',
            format: 'In-person or virtual',
            desc: 'Strategic AI literacy for C-suite and senior leaders. Covers AI opportunity assessment, risk governance, build vs buy decisions, and how to evaluate AI vendor claims.',
            outcomes: ['AI opportunity mapping for your business', 'Risk and governance framework', 'Confident AI investment decision-making'],
          },
          {
            tag: 'For Managers',
            title: 'AI-Enabled Management',
            duration: '4-week program',
            format: 'Blended: live + async',
            desc: 'For people managers who need to redesign workflows, evaluate AI tools for their teams, and manage human-AI collaboration effectively.',
            outcomes: ['Workflow redesign using AI tools', 'Team AI readiness assessment', 'Change management for AI adoption'],
          },
          {
            tag: 'For Practitioners',
            title: 'AI Skills Bootcamp',
            duration: '6-week cohort',
            format: 'Live sessions + projects',
            desc: 'Hands-on AI capability building for analysts, engineers, product managers, and domain specialists. Built around real tools and real deliverables.',
            outcomes: ['Prompt engineering for your domain', 'AI tool proficiency certification', 'Capstone project using your actual work'],
          },
          {
            tag: 'Custom',
            title: 'Bespoke Programs',
            duration: 'Designed to spec',
            format: 'Any format',
            desc: 'Fully custom programs for specific functions — sales AI, HR automation, finance analytics, customer service AI. We design from scratch around your context.',
            outcomes: ['Function-specific AI skills', 'Custom scenario and case study development', 'Train-the-trainer option available'],
          },
        ].map(p => (
          <div class="program-card">
            <div class="program-header">
              <p class="badge">{p.tag}</p>
              <h3>{p.title}</h3>
              <div class="program-meta">
                <span>⏱ {p.duration}</span>
                <span>📍 {p.format}</span>
              </div>
            </div>
            <p class="program-desc">{p.desc}</p>
            <div class="program-outcomes">
              <p class="outcomes-label">Key outcomes</p>
              <ul>
                {p.outcomes.map(o => <li>{o}</li>)}
              </ul>
            </div>
            <a href="/contact" class="btn btn--outline program-cta">Enquire →</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="process section section--dark">
    <div class="container">
      <div class="section-header section-header--light">
        <p class="badge">Our Process</p>
        <h2 style="color:white">How we design and deliver.</h2>
      </div>
      <div class="process-steps">
        {[
          { n: '01', title: 'Discovery call',        body: 'We understand your team, tools, current skills, and what "better" looks like for you.' },
          { n: '02', title: 'Skill gap assessment',  body: 'Optional pre-assessment to baseline current AI literacy across your team.' },
          { n: '03', title: 'Program design',        body: 'We build a custom curriculum using your tools, your workflows, and real scenarios from your industry.' },
          { n: '04', title: 'Pilot cohort',          body: 'We run a first cohort with a small group, gather feedback, and refine before scaling.' },
          { n: '05', title: 'Full rollout',           body: 'Program runs across your organisation with facilitator support and progress tracking.' },
          { n: '06', title: 'Impact measurement',    body: 'Post-program assessment and manager feedback to quantify behaviour change.' },
        ].map(s => (
          <div class="process-step">
            <div class="step-n">{s.n}</div>
            <h3>{s.title}</h3>
            <p>{s.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Lead Magnet -->
  <section class="section section--tinted">
    <div class="container">
      <div class="lm-card">
        <div class="lm-left">
          <p class="lm-eyebrow">Free Resource</p>
          <h3>AI Skills Gap Assessment Template</h3>
          <p>A 7-question diagnostic to baseline your team's current AI literacy — and prioritise which skills to build first. Includes a scoring guide and recommendations by role.</p>
          <ul class="lm-bullets">
            <li>Questions segmented by role (exec, manager, practitioner)</li>
            <li>Scoring rubric with maturity levels</li>
            <li>Recommended training path for each level</li>
          </ul>
        </div>
        <div class="lm-right">
          <p class="lm-how">How to get it</p>
          <ol class="lm-steps">
            <li>Tap the button below</li>
            <li>WhatsApp opens with a ready-to-send message</li>
            <li>Hit send — we'll reply with the assessment</li>
          </ol>
          <a href="https://wa.me/919876656573?text=Hi%21+Send+me+the+AI+Skills+Gap+Assessment" target="_blank" rel="noopener" class="btn lm-wa-btn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp us for the free assessment
          </a>
          <a href="https://pub-4c93a5990adb4ca28f9f94e80575b0d8.r2.dev/AI-Skills-Gap-Assessment-SnapSkill.pdf" target="_blank" rel="noopener" class="lm-direct-link">or download directly →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container" style="max-width:640px;text-align:center">
      <h2>Let's design something<br>that actually works.</h2>
      <p style="margin:var(--space-sm) 0 var(--space-lg)">Tell us about your team — size, roles, current AI maturity — and we'll come back with a program design within 48 hours.</p>
      <a href="https://wa.me/919876656573?text=Hi%21+I%27d+like+to+discuss+corporate+AI+training+for+my+team." target="_blank" rel="noopener" class="btn btn--primary ct-wa-btn">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Start the conversation on WhatsApp
      </a>
    </div>
  </section>

  </main>
  <Footer />
</BaseLayout>

<style>
  .section { padding: var(--space-2xl) 0; }
  .section--tinted { background: var(--color-surface); }
  .section--dark   { background: var(--color-dark); }
  .section-header  { text-align: center; margin-bottom: var(--space-xl); max-width: 600px; margin-inline: auto; }
  .section-header .badge { margin-bottom: var(--space-sm); }
  .section-header h2 { margin: var(--space-xs) 0 var(--space-sm); }
  .section-header--light p { color: rgba(255,255,255,0.65); }

  /* Hero */
  .ct-hero { padding: var(--space-2xl) 0 var(--space-xl); border-bottom: 1px solid var(--color-border); }
  .hero-inner { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-xl); align-items: center; }
  .hero-text .badge { margin-bottom: var(--space-md); }
  .hero-text h1 { margin-bottom: var(--space-md); }
  .hero-sub { font-size: 1.05rem; max-width: 480px; margin-bottom: var(--space-lg); }
  .hero-actions { display: flex; gap: var(--space-sm); flex-wrap: wrap; }
  /* Training dashboard visual */
  .hero-visual { }
  .training-dash { background: #0d1117; border: 1px solid rgba(255,255,255,0.1); border-radius: 16px; overflow: hidden; box-shadow: 0 30px 60px rgba(0,0,0,0.3); animation: dashIn 0.7s ease 0.3s both; }
  @keyframes dashIn { from { opacity:0; transform:translateY(16px); } to { opacity:1; transform:translateY(0); } }
  .td-topbar { background: #161b22; padding: 10px 14px; display: flex; align-items: center; gap: 8px; border-bottom: 1px solid rgba(255,255,255,0.06); }
  .td-logo-dot { width: 18px; height: 18px; border-radius: 5px; background: var(--color-primary); flex-shrink: 0; }
  .td-title { font-size: 0.78rem; font-weight: 600; color: rgba(255,255,255,0.7); flex: 1; }
  .td-live { display: flex; align-items: center; gap: 5px; font-size: 0.62rem; font-weight: 700; color: #10b981; }
  .td-live-dot { width: 6px; height: 6px; border-radius: 50%; background: #10b981; animation: livePulse 2s infinite; }
  @keyframes livePulse { 0%,100% { box-shadow:0 0 0 2px rgba(16,185,129,0.2); } 50% { box-shadow:0 0 0 5px rgba(16,185,129,0.05); } }
  .td-body { padding: 14px; display: flex; flex-direction: column; gap: 12px; }
  .td-stats { display: grid; grid-template-columns: repeat(3,1fr); gap: 8px; }
  .tds { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06); border-radius: 8px; padding: 10px; text-align: center; }
  .tds-num { font-family: var(--font-heading); font-size: 1.3rem; font-weight: 800; color: white; line-height: 1; }
  .tds-num span { font-size: 0.85rem; color: var(--color-accent); }
  .tds-label { font-size: 0.6rem; color: rgba(255,255,255,0.35); margin-top: 3px; }
  .td-section-label { font-size: 0.6rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: rgba(255,255,255,0.3); }
  .td-cohorts { display: flex; flex-direction: column; gap: 6px; }
  .tdc-row { display: flex; align-items: center; gap: 7px; }
  .tdc-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
  .tdc-name { font-size: 0.67rem; color: rgba(255,255,255,0.6); width: 140px; flex-shrink: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .tdc-bar { flex: 1; height: 5px; background: rgba(255,255,255,0.07); border-radius: 3px; overflow: hidden; }
  .tdc-fill { height: 100%; width: var(--w); background: linear-gradient(90deg, var(--color-primary), var(--color-accent)); border-radius: 3px; animation: barGrow 1.1s ease 0.5s both; }
  @keyframes barGrow { from { width: 0; } }
  .tdc-pct { font-size: 0.62rem; color: rgba(255,255,255,0.35); width: 28px; text-align: right; }
  /* Skill lift */
  .td-lift { display: flex; flex-direction: column; gap: 7px; }
  .tdl-row { display: flex; align-items: center; gap: 8px; }
  .tdl-row span:first-child { font-size: 0.65rem; color: rgba(255,255,255,0.55); width: 130px; flex-shrink: 0; }
  .tdl-bars { flex: 1; display: flex; flex-direction: column; gap: 2px; }
  .tdl-before { height: 4px; width: var(--bw); background: rgba(255,255,255,0.15); border-radius: 2px; }
  .tdl-after  { height: 4px; width: var(--aw); background: linear-gradient(90deg, var(--color-primary), #10b981); border-radius: 2px; animation: barGrow 1s ease 0.7s both; }
  .tdl-delta { font-size: 0.62rem; font-weight: 700; color: #10b981; width: 40px; text-align: right; flex-shrink: 0; }
  .tdl-legend { display: flex; gap: 10px; margin-top: 2px; }
  .tdl-leg { font-size: 0.58rem; font-weight: 600; padding: 2px 6px; border-radius: 100px; }
  .tdl-leg--before { background: rgba(255,255,255,0.07); color: rgba(255,255,255,0.4); }
  .tdl-leg--after  { background: rgba(0,123,255,0.2); color: #60a5fa; }
  /* Feed */
  .td-feed { display: flex; flex-direction: column; gap: 5px; }
  .tdf-item { display: flex; align-items: center; gap: 7px; font-size: 0.63rem; color: rgba(255,255,255,0.5); background: rgba(255,255,255,0.03); padding: 5px 8px; border-radius: 6px; opacity: 0; }
  .tdf-item b { color: rgba(255,255,255,0.8); }
  .tdf-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }
  .tdf-dot.green { background: #10b981; }
  .tdf-dot.blue  { background: var(--color-primary); }
  .tdf-item--1 { animation: feedIn 0.4s ease 1.2s both; }
  .tdf-item--2 { animation: feedIn 0.4s ease 1.5s both; }
  @keyframes feedIn { from { opacity:0; transform:translateX(-6px); } to { opacity:1; transform:translateX(0); } }

  /* Problem */
  .problem-inner { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-xl); align-items: start; }
  .problem-text .badge { margin-bottom: var(--space-sm); }
  .problem-text h2 { margin-bottom: var(--space-md); }
  .problem-text p  { margin-bottom: var(--space-sm); font-size: 0.95rem; }
  .problem-vs { display: flex; gap: var(--space-sm); align-items: stretch; }
  .vs-col { flex: 1; padding: var(--space-md); border-radius: var(--radius-md); }
  .vs-col--bad  { background: #fff5f5; border: 1px solid #fecaca; }
  .vs-col--good { background: #f0fff4; border: 1px solid #a7f3d0; }
  .vs-col h3 { font-size: 0.9rem; margin-bottom: var(--space-sm); }
  .vs-col--bad  h3 { color: #b91c1c; }
  .vs-col--good h3 { color: #065f46; }
  .vs-col ul { padding-left: var(--space-md); }
  .vs-col li { font-size: 0.85rem; margin-bottom: 6px; }
  .vs-col--bad  li { color: #7f1d1d; }
  .vs-col--good li { color: #064e3b; }
  .vs-divider { display: flex; align-items: center; font-family: var(--font-heading); font-weight: 800; color: var(--color-body); font-size: 0.9rem; }

  /* Programs */
  .programs-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-md); }
  .program-card { padding: var(--space-lg); border: 1px solid var(--color-border); border-radius: var(--radius-lg); background: white; display: flex; flex-direction: column; gap: var(--space-sm); transition: var(--transition); }
  .program-card:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); }
  .program-header .badge { margin-bottom: var(--space-xs); }
  .program-header h3 { margin-bottom: var(--space-xs); }
  .program-meta { display: flex; gap: var(--space-md); font-size: 0.82rem; color: var(--color-body); }
  .program-desc { font-size: 0.9rem; }
  .program-outcomes { background: var(--color-surface); border-radius: var(--radius-sm); padding: var(--space-sm); flex: 1; }
  .outcomes-label { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: var(--space-xs); color: var(--color-body); }
  .program-outcomes ul { padding-left: var(--space-md); }
  .program-outcomes li { font-size: 0.85rem; margin-bottom: 4px; }
  .program-cta { align-self: flex-start; }

  /* Process */
  .process-steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-md); }
