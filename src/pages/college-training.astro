---
import BaseLayout from '../layouts/BaseLayout.astro'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'
---

<BaseLayout
  title="AI Training for Colleges & Universities"
  description="AI, Data Science & Data Engineering programs designed to help colleges produce graduates recruiters actually want to hire. Placement Sprints, Semester Takeovers, and Faculty Development from practitioners who've built AI, not just taught it."
>
  <Nav />
  <main>

  <!-- ═══════════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════════ -->
  <section class="cg-hero">
    <div class="hero-bg" aria-hidden="true">
      <div class="hero-orb hero-orb--1"></div>
      <div class="hero-orb hero-orb--2"></div>
      <div class="hero-orb hero-orb--3"></div>
    </div>
    <div class="container">
      <div class="hero-inner">
        <div class="hero-text">
          <p class="badge badge--accent hero-in hero-in--1">For Colleges &amp; Universities</p>
          <h1 class="hero-in hero-in--2">AI training that doesn't end with a certificate.<br>It ends with <span class="text-gradient">better placements.</span></h1>
          <p class="hero-sub hero-in hero-in--3">Placement season doesn't wait for curriculum revisions. Recruiters don't hire based on attendance. And students don't remember the syllabus — they remember the projects they built, the interviews they cracked, and the offers they received.</p>
          <div class="hero-actions hero-in hero-in--4">
            <a href="/contact" class="btn btn--primary">Book a Consultation</a>
            <a href="#programs" class="btn btn--outline">See the programs</a>
          </div>
        </div>

        <!-- Animated placement-readiness dashboard visual -->
        <div class="hero-visual hero-in hero-in--3" aria-hidden="true">
          <div class="hero-float-chip hero-float-chip--1">🎓 Interview Ready</div>
          <div class="hero-float-chip hero-float-chip--2">📈 +58pts confidence</div>
          <div class="training-dash">
            <div class="td-topbar">
              <div class="td-logo-dot"></div>
              <div class="td-title">Placement Readiness</div>
              <div class="td-live"><span class="td-live-dot"></span>Live</div>
            </div>
            <div class="td-body">
              <div class="td-stats">
                <div class="tds"><div class="tds-num" data-count="3" data-suffix="wk">0<span>wk</span></div><div class="tds-label">To first cohort</div></div>
                <div class="tds"><div class="tds-num" data-count="100" data-suffix="%">0<span>%</span></div><div class="tds-label">Project-based</div></div>
                <div class="tds"><div class="tds-num" data-count="3" data-suffix="">0</div><div class="tds-label">Delivery tracks</div></div>
              </div>
              <div class="td-section-label">Active Tracks</div>
              <div class="td-cohorts">
                <div class="tdc-row"><div class="tdc-dot" style="background:#007BFF"></div><span class="tdc-name">Placement Sprint</span><div class="tdc-bar"><div class="tdc-fill" style="--w:100%"></div></div><span class="tdc-pct">Done</span></div>
                <div class="tdc-row"><div class="tdc-dot" style="background:#FFC300"></div><span class="tdc-name">Semester Takeover</span><div class="tdc-bar"><div class="tdc-fill" style="--w:64%"></div></div><span class="tdc-pct">64%</span></div>
                <div class="tdc-row"><div class="tdc-dot" style="background:#14b8a6"></div><span class="tdc-name">Faculty Development</span><div class="tdc-bar"><div class="tdc-fill" style="--w:41%"></div></div><span class="tdc-pct">41%</span></div>
              </div>
              <div class="td-section-label">Interview Confidence · Cohort vs Baseline</div>
              <div class="td-lift">
                <div class="tdl-row"><span>GitHub portfolio ready</span><div class="tdl-bars"><div class="tdl-before" style="--bw:12%"></div><div class="tdl-after" style="--aw:88%"></div></div><span class="tdl-delta">+76pts</span></div>
                <div class="tdl-row"><span>Mock interview score</span><div class="tdl-bars"><div class="tdl-before" style="--bw:24%"></div><div class="tdl-after" style="--aw:81%"></div></div><span class="tdl-delta">+57pts</span></div>
                <div class="tdl-row"><span>Technical Q&amp;A depth</span><div class="tdl-bars"><div class="tdl-before" style="--bw:19%"></div><div class="tdl-after" style="--aw:77%"></div></div><span class="tdl-delta">+58pts</span></div>
                <div class="tdl-legend"><span class="tdl-leg tdl-leg--before">Day 1</span><span class="tdl-leg tdl-leg--after">Interview Ready</span></div>
              </div>
              <div class="td-feed">
                <div class="tdf-item tdf-item--1"><div class="tdf-dot green"></div><span>Student pushed capstone to <b>GitHub</b></span></div>
                <div class="tdf-item tdf-item--2"><div class="tdf-dot blue"></div><span>Mock interview completed · <b>Confident</b></span></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Trusted by strip (auto-scrolling marquee) -->
      <div class="trusted-strip hero-in hero-in--5">
        <span class="trusted-label">Trusted by Institutions &amp; Industry</span>
        <div class="trusted-marquee">
          <div class="trusted-track">
            <span>Numaligarh Refinery (NRL)</span>
            <span class="trusted-dot">•</span>
            <span>CVR College of Engineering</span>
            <span class="trusted-dot">•</span>
            <span>Lovely Professional University</span>
            <span class="trusted-dot">•</span>
            <span aria-hidden="true">Numaligarh Refinery (NRL)</span>
            <span class="trusted-dot" aria-hidden="true">•</span>
            <span aria-hidden="true">CVR College of Engineering</span>
            <span class="trusted-dot" aria-hidden="true">•</span>
            <span aria-hidden="true">Lovely Professional University</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       ANIMATED EXPLAINER — the placement journey, autoplaying scenes
  ═══════════════════════════════════════════════ -->
  <section class="section explainer-section">
    <div class="container reveal" style="max-width:820px">
      <div class="section-header" style="margin-bottom:var(--space-md)">
        <p class="badge">The Journey, In 20 Seconds</p>
        <h2>From day one to interview-ready.</h2>
      </div>

      <div class="explainer-stage" aria-hidden="true">
        <div class="explainer-progress">
          <span class="ep-seg ep-seg--1"><span></span></span>
          <span class="ep-seg ep-seg--2"><span></span></span>
          <span class="ep-seg ep-seg--3"><span></span></span>
          <span class="ep-seg ep-seg--4"><span></span></span>
          <span class="ep-seg ep-seg--5"><span></span></span>
        </div>

        <div class="explainer-scenes">

          <!-- Scene 1 — The problem -->
          <div class="escene escene--1">
            <div class="escene-visual">
              <div class="ev-clock">
                <div class="ev-clock-hand ev-clock-hand--h"></div>
                <div class="ev-clock-hand ev-clock-hand--m"></div>
              </div>
              <div class="ev-badge ev-badge--red">Placement season</div>
            </div>
            <p class="escene-title">Placement season is closer than it looks.</p>
            <p class="escene-sub">AI moves every month. Curriculums don't.</p>
          </div>

          <!-- Scene 2 — Choosing the track -->
          <div class="escene escene--2">
            <div class="escene-visual">
              <div class="ev-dot ev-dot--blue">🚀</div>
              <div class="ev-dot ev-dot--yellow">📚</div>
              <div class="ev-dot ev-dot--teal">🎓</div>
            </div>
            <p class="escene-title">We design the right track for you.</p>
            <p class="escene-sub">Placement Sprint, Semester Takeover, or Faculty Development.</p>
          </div>

          <!-- Scene 3 — Building -->
          <div class="escene escene--3">
            <div class="escene-visual">
              <div class="ev-commits">
                <span></span><span></span><span></span><span></span><span></span>
              </div>
              <div class="ev-badge ev-badge--blue">GitHub-ready</div>
            </div>
            <p class="escene-title">Students ship real projects.</p>
            <p class="escene-sub">Not slideware — portfolios recruiters can actually open.</p>
          </div>

          <!-- Scene 4 — Interview -->
          <div class="escene escene--4">
            <div class="escene-visual">
              <div class="ev-chat ev-chat--q">Tell me about a project you're proud of.</div>
              <div class="ev-chat ev-chat--a">Sure — here's the architecture on GitHub...</div>
            </div>
            <p class="escene-title">They walk in ready to explain it.</p>
            <p class="escene-sub">Confident answers, not memorized ones.</p>
          </div>

          <!-- Scene 5 — Outcome -->
          <div class="escene escene--5">
            <div class="escene-visual">
              <div class="ev-trophy">🏆</div>
              <div class="ev-confetti">
                <span></span><span></span><span></span><span></span><span></span><span></span>
              </div>
            </div>
            <p class="escene-title">Confident. Not just certified.</p>
            <p class="escene-sub">That's what changes how the interview goes.</p>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       IN THE NEWS — real data backing the urgency
  ═══════════════════════════════════════════════ -->
  <section class="section news-section">
    <div class="container">
      <div class="section-header reveal">
        <p class="badge">Not Just Our Opinion</p>
        <h2>This is already making headlines.</h2>
        <p>A snapshot of what's being reported about AI, hiring, and graduate readiness — in India and globally.</p>
      </div>

      <div class="clip-grid">
        <div class="clip-card reveal">
          <p class="clip-source">Monster · 2026 Graduate AI Readiness Report</p>
          <p class="clip-stat">89% of graduates now fear AI could replace entry-level roles</p>
          <p class="clip-context">Up from 64% a year earlier — while only 36% say their college is preparing them for it.</p>
        </div>
        <div class="clip-card reveal">
          <p class="clip-source">Mercer-Mettl · India Graduate Skill Index</p>
          <p class="clip-stat">Only 42.6% of Indian graduates are considered industry-ready</p>
          <p class="clip-context">The employability gap recruiters are already filtering candidates against.</p>
        </div>
        <div class="clip-card reveal">
          <p class="clip-source">NIIT · India Skills Gap Report 2026</p>
          <p class="clip-stat">AI literacy is now the hardest skill for Indian employers to find</p>
          <p class="clip-context">Reports describe a degree without AI fluency in 2026 as comparable to entering the 2005 workforce without basic computer literacy.</p>
        </div>
        <div class="clip-card reveal">
          <p class="clip-source">Cengage Group · 2026 Employability Report</p>
          <p class="clip-stat">Entry-level job postings are down 35% in eighteen months</p>
          <p class="clip-context">As AI absorbs the tasks that used to train new hires on the job.</p>
        </div>
        <div class="clip-card reveal">
          <p class="clip-source">India Skills Report 2026 · ETS, CII, AICTE, AIU</p>
          <p class="clip-stat">National employability stands at 56.35%</p>
          <p class="clip-context">Which still leaves roughly 44 of every 100 graduates outside the bar recruiters are setting.</p>
        </div>
        <div class="clip-card clip-card--statement reveal">
          <p class="clip-source">Said at the TCS AGM, June 2026</p>
          <p class="clip-stat">India's largest IT employer is preparing for AI agents at workforce scale</p>
          <p class="clip-context">TCS Chairman N. Chandrasekaran told shareholders that a company running half a million employees today may soon be operating alongside a similarly large fleet of AI agents.</p>
        </div>
      </div>
      <p class="clip-footnote reveal">Sources paraphrased from publicly reported research and statements. Figures reflect the reports cited as of mid-2026.</p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       THE PROBLEM — the equation every college is solving
  ═══════════════════════════════════════════════ -->
  <section class="problem section section--tinted">
    <div class="container problem-inner">
      <div class="problem-text reveal">
        <p class="badge">The Equation</p>
        <h2>Every college is trying to solve the same equation.</h2>
        <p>Better placements improve admissions. Better admissions improve rankings. Better rankings attract stronger students. It's a cycle every institution understands.</p>
        <p>But there's one missing variable: <strong>industry-ready graduates.</strong> Unfortunately, that's also the hardest part to solve for.</p>
        <p>We don't replace your faculty. We strengthen what they're already doing — with current industry expertise, modern tools, practical projects, and instructors who've built AI systems outside the classroom.</p>
      </div>
      <div class="problem-vs reveal">
        <div class="vs-col vs-col--bad">
          <h3>What makes it hard</h3>
          <ul>
            <li>AI is evolving every month</li>
            <li>Recruiters keep raising expectations</li>
            <li>Faculty already have full teaching loads</li>
            <li>Curriculum updates take time</li>
            <li>Placement season arrives whether you're ready or not</li>
          </ul>
        </div>
        <div class="vs-divider">vs</div>
        <div class="vs-col vs-col--good">
          <h3>What SnapSkill brings</h3>
          <ul>
            <li>Practitioners who track AI as it moves</li>
            <li>Programs built around what recruiters ask for</li>
            <li>Delivery that adds to faculty, not onto them</li>
            <li>Current tools, current projects, every cohort</li>
            <li>Timelines built backwards from your placement calendar</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       WHY COLLEGES CHOOSE SNAPSKILL
  ═══════════════════════════════════════════════ -->
  <section class="section quote-section">
    <div class="container" style="max-width:760px;text-align:center">
      <p class="badge reveal">Why Colleges Choose SnapSkill</p>
      <h2 class="reveal">Lots of companies teach AI.<br>Very few have actually built it.</h2>
      <p class="reveal" style="margin-top:var(--space-sm)">Fewer still have successfully brought that experience into classrooms. That's the difference.</p>
      <blockquote class="cg-pull-quote reveal"><span class="quote-mark" aria-hidden="true">"</span>We're an AI company that also teaches. Not a training company that recently discovered AI.</blockquote>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       PROOF — paying professionals + NRL
  ═══════════════════════════════════════════════ -->
  <section class="proof section section--dark">
    <div class="proof-bg" aria-hidden="true">
      <div class="proof-orb proof-orb--1"></div>
      <div class="proof-orb proof-orb--2"></div>
    </div>
    <div class="container">
      <div class="proof-grid">
        <div class="proof-card reveal">
          <div class="proof-icon proof-icon--blue" aria-hidden="true">🏆</div>
          <p class="badge badge--accent">Earned, Not Given</p>
          <h3 style="color:white">We've earned the trust of paying professionals.</h3>
          <p>Our flagship <strong style="color:white">Data Science Ninja</strong> program wasn't built for captive classrooms — it's a paid program for working professionals who invest their own money because they expect better career opportunities.</p>
          <p>People paying out of pocket don't tolerate outdated content, generic lectures, or theoretical exercises. They expect practical learning, relevance, and results. That's exactly how we teach college students too — recruiters don't lower the bar simply because someone is graduating.</p>
        </div>
        <div class="proof-card reveal">
          <div class="proof-icon proof-icon--teal" aria-hidden="true">🔬</div>
          <p class="badge badge--accent">Built in the Field</p>
          <h3 style="color:white">We teach AI because we've built AI.</h3>
          <p>When <strong style="color:white">Numaligarh Refinery (NRL)</strong> partnered with us, they weren't looking for another AI awareness workshop. They needed AI that solved real business problems.</p>
          <p>We worked on a live computer vision solution for automated spare-parts extraction, and delivered enterprise generative AI training to engineering teams responsible for adopting AI inside one of India's leading refineries. There's a difference between teaching AI concepts and teaching from experience. Students notice it. Faculty notice it. Recruiters certainly notice it.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       DELIVERED INSIDE REAL COLLEGES
  ═══════════════════════════════════════════════ -->
  <section class="delivered section">
    <div class="container">
      <div class="section-header reveal">
        <p class="badge">Proven on Campus</p>
        <h2>We've delivered inside real colleges.</h2>
        <p>Different faculty. Different infrastructure. Different expectations. Different student preparedness. Our programs adapt to the college, not the other way around.</p>
      </div>
      <div class="delivered-grid">
        <div class="delivered-card reveal">
          <div class="delivered-avatar delivered-avatar--ring-blue" aria-hidden="true">RS</div>
          <h3>CVR College of Engineering</h3>
          <p class="delivered-by">Delivered by Dr. Rajitha Somina, Lead AI Research Scientist at SnapSkill.</p>
        </div>
        <div class="delivered-card reveal">
          <img src="/pooja.jpeg" alt="Pooja Chaurasia, CEO, SnapSkill" class="delivered-photo delivered-photo--ring-teal" />
          <h3>Lovely Professional University</h3>
          <p class="delivered-by">Delivered by Pooja Chaurasia, CEO, SnapSkill.</p>
        </div>
      </div>
      <p class="delivered-footer reveal">Different institutions. Same philosophy: teach what industry actually uses.</p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       THREE WAYS WE CAN WORK TOGETHER
  ═══════════════════════════════════════════════ -->
  <section class="programs section section--tinted" id="programs">
    <div class="container">
      <div class="section-header reveal">
        <p class="badge">Three Ways We Can Work Together</p>
        <h2>No two colleges have<br>the same challenge.</h2>
        <p>That's why we don't force every institution into the same program. Instead, we solve the problem you're trying to solve.</p>
      </div>

      <div class="programs-grid">
        {[
          {
            icon: '🚀',
            color: 'blue',
            tag: 'Placement Season Is Close',
            title: 'Placement Sprint',
            duration: '2–3 month program',
            format: 'Final-year students',
            desc: "Designed for final-year students preparing for campus recruitment over the next two to three months. Students don't leave with another certificate — they leave with projects they can confidently discuss in interviews.",
            outcomes: ['AI fundamentals employers expect', 'Data Science & Data Engineering workflows', 'Hands-on industry projects', 'GitHub portfolio, resume, mock interviews'],
            fit: 'Third & fourth-year students · Colleges approaching placement season',
          },
          {
            icon: '📚',
            color: 'yellow',
            tag: 'Curriculum Modernization',
            title: 'Semester Takeover',
            duration: 'Full semester',
            format: 'Credit-bearing electives',
            desc: 'Modern AI education without asking faculty to rebuild an entire curriculum. We design and deliver complete semester-long AI, Data Science or Data Engineering modules — current, project-based, and reflecting what companies hire for today.',
            outcomes: ['Complete module design & delivery', 'Project-based assessment', 'Integrates with existing academic structure'],
            fit: 'AI specializations · Department partnerships',
          },
          {
            icon: '🎓',
            color: 'teal',
            tag: 'Long-Term Capability',
            title: 'Faculty Development Program',
            duration: 'Cohort-based',
            format: 'For teaching faculty',
            desc: "Build capability that stays after we leave. The strongest colleges don't rely on external trainers forever — they develop faculty who can confidently teach emerging technologies themselves.",
            outcomes: ['Practical AI knowledge & teaching resources', 'Classroom exercises and confidence-building', 'Strengthens NAAC / NBA accreditation documentation'],
            fit: 'Faculty upskilling · Accreditation initiatives',
          },
        ].map(p => (
          <div class={`program-card program-card--${p.color} reveal`}>
            <div class="program-icon-circle">{p.icon}</div>
            <div class="program-header">
              <p class="badge">{p.tag}</p>
              <h3>{p.title}</h3>
              <div class="program-meta">
                <span>⏱ {p.duration}</span>
                <span>🎯 {p.format}</span>
              </div>
            </div>
            <p class="program-desc">{p.desc}</p>
            <div class="program-outcomes">
              <p class="outcomes-label">Students / faculty leave with</p>
              <ul>
                {p.outcomes.map(o => <li>{o}</li>)}
              </ul>
            </div>
            <p class="program-fit">Best suited for: {p.fit}</p>
            <a href="/contact" class="btn btn--outline program-cta">Enquire →</a>
          </div>
        ))}
      </div>

      <!-- Need something different -->
      <div class="need-different reveal">
        <h3>Need something different?</h3>
        <p>Many institutions need something that doesn't fit neatly inside a brochure. That's perfectly fine — neither do most real problems. If your challenge is unique, we'll build a solution around it.</p>
        <div class="chip-row">
          {['AI Centres of Excellence', 'Curriculum consulting', 'Industry-sponsored projects', 'Student innovation labs', 'Hackathons', 'Faculty mentoring', 'Custom AI initiatives'].map(c => (
            <span class="chip">{c}</span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       WHY SNAPSKILL — comparison table
  ═══════════════════════════════════════════════ -->
  <section class="compare section">
    <div class="container">
      <div class="section-header reveal">
        <p class="badge">Why SnapSkill?</p>
        <h2>Not another training vendor.</h2>
      </div>
      <div class="compare-table-wrap reveal">
        <table class="compare-table">
          <thead>
            <tr><th>Typical Training Vendor</th><th>SnapSkill</th></tr>
          </thead>
          <tbody>
            {[
              ['Teaches AI concepts', 'Builds AI systems and teaches them'],
              ['Generic instructors', 'Programs led by founders and senior AI practitioners'],
              ['Static curriculum', 'Continuously updated with industry trends'],
              ['Certificate-focused', 'Portfolio and interview focused'],
              ['Theory-heavy', 'Project-first learning'],
              ["One-size-fits-all", "Designed around each institution's needs"],
            ].map(([bad, good]) => (
              <tr>
                <td class="compare-bad"><span class="compare-icon compare-icon--bad">✕</span>{bad}</td>
                <td class="compare-good"><span class="compare-icon compare-icon--good">✓</span>{good}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       WHAT SUCCESS LOOKS LIKE
  ═══════════════════════════════════════════════ -->
  <section class="success section section--dark">
    <div class="container">
      <div class="section-header section-header--light reveal">
        <p class="badge">What Success Looks Like</p>
        <h2 style="color:white">Imagine your next placement season.</h2>
      </div>
      <div class="success-flow">
        <div class="success-q reveal">
          <span class="success-q-mark">"</span>
          Tell me about a project you're proud of.
        </div>
        <div class="success-steps success-steps--timeline">
          {[
            'Instead of searching for the right answer...',
            'the student opens GitHub.',
            'Explains the architecture.',
            'Describes the challenges.',
            'Demonstrates the solution.',
            'Answers follow-up questions confidently.',
          ].map((s, i) => (
            <div class="success-step reveal">
              <span class="success-step-n">{String(i + 1).padStart(2, '0')}</span>
              <span>{s}</span>
            </div>
          ))}
        </div>
        <p class="success-note reveal">That's a very different interview. And it starts months before the recruiter walks into campus. Not better certificates — better conversations between students and recruiters.</p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       OUR PHILOSOPHY
  ═══════════════════════════════════════════════ -->
  <section class="section">
    <div class="container" style="max-width:680px;text-align:center">
      <p class="badge reveal">Our Philosophy</p>
      <h2 class="reveal">Technology changes.<br>Learning doesn't.</h2>
      <p class="reveal" style="margin-top:var(--space-sm)">People remember what they build. They remember what they solve. And employers hire people who can demonstrate capability, not just completion.</p>
      <blockquote class="cg-pull-quote reveal">"Will this help a student perform better during an interview?" If the answer is no, it doesn't belong in the program.</blockquote>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       FAQ
  ═══════════════════════════════════════════════ -->
  <section class="faq section section--tinted">
    <div class="container" style="max-width:760px">
      <div class="section-header reveal">
        <p class="badge">Frequently Asked Questions</p>
        <h2>Let's answer the practical stuff.</h2>
      </div>
      <div class="faq-list">
        {[
