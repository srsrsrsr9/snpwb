---
import BaseLayout from '../layouts/BaseLayout.astro'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'
---

<BaseLayout
  title="AI Training for Colleges & Universities"
  description="AI, Data Science & Data Engineering programs designed to help colleges produce graduates recruiters actually want to hire. Placement Sprints, Semester Takeovers, and Faculty Development from practitioners who've built AI, not just taught it."
>
  <Nav />
  <main>

  <!-- ═══════════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════════ -->
  <section class="cg-hero">
    <div class="container">
      <div class="hero-inner">
        <div class="hero-text">
          <p class="badge badge--accent">For Colleges &amp; Universities</p>
          <h1>AI training that doesn't end with a certificate.<br>It ends with <span class="text-primary">better placements.</span></h1>
          <p class="hero-sub">Placement season doesn't wait for curriculum revisions. Recruiters don't hire based on attendance. And students don't remember the syllabus — they remember the projects they built, the interviews they cracked, and the offers they received.</p>
          <div class="hero-actions">
            <a href="/contact" class="btn btn--primary">Book a Consultation</a>
            <a href="#programs" class="btn btn--outline">See the programs</a>
          </div>
        </div>

        <!-- Animated placement-readiness dashboard visual -->
        <div class="hero-visual" aria-hidden="true">
          <div class="training-dash">
            <div class="td-topbar">
              <div class="td-logo-dot"></div>
              <div class="td-title">Placement Readiness</div>
              <div class="td-live"><span class="td-live-dot"></span>Live</div>
            </div>
            <div class="td-body">
              <div class="td-stats">
                <div class="tds"><div class="tds-num">3<span>wk</span></div><div class="tds-label">To first cohort</div></div>
                <div class="tds"><div class="tds-num">100<span>%</span></div><div class="tds-label">Project-based</div></div>
                <div class="tds"><div class="tds-num">3</div><div class="tds-label">Delivery tracks</div></div>
              </div>
              <div class="td-section-label">Active Tracks</div>
              <div class="td-cohorts">
                <div class="tdc-row"><div class="tdc-dot" style="background:#007BFF"></div><span class="tdc-name">Placement Sprint</span><div class="tdc-bar"><div class="tdc-fill" style="--w:100%"></div></div><span class="tdc-pct">Done</span></div>
                <div class="tdc-row"><div class="tdc-dot" style="background:#FFC300"></div><span class="tdc-name">Semester Takeover</span><div class="tdc-bar"><div class="tdc-fill" style="--w:64%"></div></div><span class="tdc-pct">64%</span></div>
                <div class="tdc-row"><div class="tdc-dot" style="background:#10b981"></div><span class="tdc-name">Faculty Development</span><div class="tdc-bar"><div class="tdc-fill" style="--w:41%"></div></div><span class="tdc-pct">41%</span></div>
              </div>
              <div class="td-section-label">Interview Confidence · Cohort vs Baseline</div>
              <div class="td-lift">
                <div class="tdl-row"><span>GitHub portfolio ready</span><div class="tdl-bars"><div class="tdl-before" style="--bw:12%"></div><div class="tdl-after" style="--aw:88%"></div></div><span class="tdl-delta">+76pts</span></div>
                <div class="tdl-row"><span>Mock interview score</span><div class="tdl-bars"><div class="tdl-before" style="--bw:24%"></div><div class="tdl-after" style="--aw:81%"></div></div><span class="tdl-delta">+57pts</span></div>
                <div class="tdl-row"><span>Technical Q&amp;A depth</span><div class="tdl-bars"><div class="tdl-before" style="--bw:19%"></div><div class="tdl-after" style="--aw:77%"></div></div><span class="tdl-delta">+58pts</span></div>
                <div class="tdl-legend"><span class="tdl-leg tdl-leg--before">Day 1</span><span class="tdl-leg tdl-leg--after">Placement Ready</span></div>
              </div>
              <div class="td-feed">
                <div class="tdf-item tdf-item--1"><div class="tdf-dot green"></div><span>Student pushed capstone to <b>GitHub</b></span></div>
                <div class="tdf-item tdf-item--2"><div class="tdf-dot blue"></div><span>Mock interview completed · <b>Confident</b></span></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Trusted by strip -->
      <div class="trusted-strip">
        <span class="trusted-label">Trusted by Institutions &amp; Industry</span>
        <div class="trusted-names">
          <span>Numaligarh Refinery (NRL)</span>
          <span class="trusted-dot">•</span>
          <span>CVR College of Engineering</span>
          <span class="trusted-dot">•</span>
          <span>Lovely Professional University</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       THE PROBLEM — the equation every college is solving
  ═══════════════════════════════════════════════ -->
  <section class="problem section section--tinted">
    <div class="container problem-inner">
      <div class="problem-text">
        <p class="badge">The Equation</p>
        <h2>Every college is trying to solve the same equation.</h2>
        <p>Better placements improve admissions. Better admissions improve rankings. Better rankings attract stronger students. It's a cycle every institution understands.</p>
        <p>But there's one missing variable: <strong>industry-ready graduates.</strong> Unfortunately, that's also the hardest part to solve for.</p>
        <p>We don't replace your faculty. We strengthen what they're already doing — with current industry expertise, modern tools, practical projects, and instructors who've built AI systems outside the classroom.</p>
      </div>
      <div class="problem-vs">
        <div class="vs-col vs-col--bad">
          <h3>What makes it hard</h3>
          <ul>
            <li>AI is evolving every month</li>
            <li>Recruiters keep raising expectations</li>
            <li>Faculty already have full teaching loads</li>
            <li>Curriculum updates take time</li>
            <li>Placement season arrives whether you're ready or not</li>
          </ul>
        </div>
        <div class="vs-divider">vs</div>
        <div class="vs-col vs-col--good">
          <h3>What SnapSkill brings</h3>
          <ul>
            <li>Practitioners who track AI as it moves</li>
            <li>Programs built around what recruiters ask for</li>
            <li>Delivery that adds to faculty, not onto them</li>
            <li>Current tools, current projects, every cohort</li>
            <li>Timelines built backwards from your placement calendar</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       WHY COLLEGES CHOOSE SNAPSKILL
  ═══════════════════════════════════════════════ -->
  <section class="section">
    <div class="container" style="max-width:760px;text-align:center">
      <p class="badge">Why Colleges Choose SnapSkill</p>
      <h2>Lots of companies teach AI.<br>Very few have actually built it.</h2>
      <p style="margin-top:var(--space-sm)">Fewer still have successfully brought that experience into classrooms. That's the difference.</p>
      <blockquote class="cg-pull-quote">We're an AI company that also teaches. Not a training company that recently discovered AI.</blockquote>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       PROOF — paying professionals + NRL
  ═══════════════════════════════════════════════ -->
  <section class="proof section section--dark">
    <div class="container">
      <div class="proof-grid">
        <div class="proof-card">
          <p class="badge badge--accent">Earned, Not Given</p>
          <h3 style="color:white">We've earned the trust of paying professionals.</h3>
          <p>Our flagship <strong style="color:white">Data Science Ninja</strong> program wasn't built for captive classrooms — it's a paid program for working professionals who invest their own money because they expect better career opportunities.</p>
          <p>People paying out of pocket don't tolerate outdated content, generic lectures, or theoretical exercises. They expect practical learning, relevance, and results. That's exactly how we teach college students too — recruiters don't lower the bar simply because someone is graduating.</p>
        </div>
        <div class="proof-card">
          <p class="badge badge--accent">Built in the Field</p>
          <h3 style="color:white">We teach AI because we've built AI.</h3>
          <p>When <strong style="color:white">Numaligarh Refinery (NRL)</strong> partnered with us, they weren't looking for another AI awareness workshop. They needed AI that solved real business problems.</p>
          <p>We worked on a live computer vision solution for automated spare-parts extraction, and delivered enterprise generative AI training to engineering teams responsible for adopting AI inside one of India's leading refineries. There's a difference between teaching AI concepts and teaching from experience. Students notice it. Faculty notice it. Recruiters certainly notice it.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       DELIVERED INSIDE REAL COLLEGES
  ═══════════════════════════════════════════════ -->
  <section class="delivered section">
    <div class="container">
      <div class="section-header">
        <p class="badge">Proven on Campus</p>
        <h2>We've delivered inside real colleges.</h2>
        <p>Different faculty. Different infrastructure. Different expectations. Different student preparedness. Our programs adapt to the college, not the other way around.</p>
      </div>
      <div class="delivered-grid">
        <div class="delivered-card">
          <div class="delivered-avatar" aria-hidden="true">RS</div>
          <h3>CVR College of Engineering</h3>
          <p class="delivered-by">Delivered by Dr. Rajitha Somina, Lead AI Research Scientist at SnapSkill.</p>
        </div>
        <div class="delivered-card">
          <img src="/pooja.jpeg" alt="Pooja Chaurasia, CEO, SnapSkill" class="delivered-photo" />
          <h3>Lovely Professional University</h3>
          <p class="delivered-by">Delivered by Pooja Chaurasia, CEO, SnapSkill.</p>
        </div>
      </div>
      <p class="delivered-footer">Different institutions. Same philosophy: teach what industry actually uses.</p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       THREE WAYS WE CAN WORK TOGETHER
  ═══════════════════════════════════════════════ -->
  <section class="programs section section--tinted" id="programs">
    <div class="container">
      <div class="section-header">
        <p class="badge">Three Ways We Can Work Together</p>
        <h2>No two colleges have<br>the same challenge.</h2>
        <p>That's why we don't force every institution into the same program. Instead, we solve the problem you're trying to solve.</p>
      </div>

      <div class="programs-grid">
        {[
          {
            icon: '🚀',
            tag: 'Placement Season Is Close',
            title: 'Placement Sprint',
            duration: '2–3 month program',
            format: 'Final-year students',
            desc: "Designed for final-year students preparing for campus recruitment over the next two to three months. Students don't leave with another certificate — they leave with projects they can confidently discuss in interviews.",
            outcomes: ['AI fundamentals employers expect', 'Data Science & Data Engineering workflows', 'Hands-on industry projects', 'GitHub portfolio, resume, mock interviews'],
            fit: 'Third & fourth-year students · Colleges approaching placement season',
          },
          {
            icon: '📚',
            tag: 'Curriculum Modernization',
            title: 'Semester Takeover',
            duration: 'Full semester',
            format: 'Credit-bearing electives',
            desc: 'Modern AI education without asking faculty to rebuild an entire curriculum. We design and deliver complete semester-long AI, Data Science or Data Engineering modules — current, project-based, and reflecting what companies hire for today.',
            outcomes: ['Complete module design & delivery', 'Project-based assessment', 'Integrates with existing academic structure'],
            fit: 'AI specializations · Department partnerships',
          },
          {
            icon: '🎓',
            tag: 'Long-Term Capability',
            title: 'Faculty Development Program',
            duration: 'Cohort-based',
            format: 'For teaching faculty',
            desc: "Build capability that stays after we leave. The strongest colleges don't rely on external trainers forever — they develop faculty who can confidently teach emerging technologies themselves.",
            outcomes: ['Practical AI knowledge & teaching resources', 'Classroom exercises and confidence-building', 'Strengthens NAAC / NBA accreditation documentation'],
            fit: 'Faculty upskilling · Accreditation initiatives',
          },
        ].map(p => (
          <div class="program-card">
            <div class="program-header">
              <p class="badge">{p.icon} {p.tag}</p>
              <h3>{p.title}</h3>
              <div class="program-meta">
                <span>⏱ {p.duration}</span>
                <span>🎯 {p.format}</span>
              </div>
            </div>
            <p class="program-desc">{p.desc}</p>
            <div class="program-outcomes">
              <p class="outcomes-label">Students / faculty leave with</p>
              <ul>
                {p.outcomes.map(o => <li>{o}</li>)}
              </ul>
            </div>
            <p class="program-fit">Best suited for: {p.fit}</p>
            <a href="/contact" class="btn btn--outline program-cta">Enquire →</a>
          </div>
        ))}
      </div>

      <!-- Need something different -->
      <div class="need-different">
        <h3>Need something different?</h3>
        <p>Many institutions need something that doesn't fit neatly inside a brochure. That's perfectly fine — neither do most real problems. If your challenge is unique, we'll build a solution around it.</p>
        <div class="chip-row">
          {['AI Centres of Excellence', 'Curriculum consulting', 'Industry-sponsored projects', 'Student innovation labs', 'Hackathons', 'Faculty mentoring', 'Custom AI initiatives'].map(c => (
            <span class="chip">{c}</span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       WHY SNAPSKILL — comparison table
  ═══════════════════════════════════════════════ -->
  <section class="compare section">
    <div class="container">
      <div class="section-header">
        <p class="badge">Why SnapSkill?</p>
        <h2>Not another training vendor.</h2>
      </div>
      <div class="compare-table-wrap">
        <table class="compare-table">
          <thead>
            <tr><th>Typical Training Vendor</th><th>SnapSkill</th></tr>
          </thead>
          <tbody>
            {[
              ['Teaches AI concepts', 'Builds AI systems and teaches them'],
              ['Generic instructors', 'Programs led by founders and senior AI practitioners'],
              ['Static curriculum', 'Continuously updated with industry trends'],
              ['Certificate-focused', 'Portfolio and interview focused'],
              ['Theory-heavy', 'Project-first learning'],
              ["One-size-fits-all", "Designed around each institution's needs"],
            ].map(([bad, good]) => (
              <tr>
                <td class="compare-bad">{bad}</td>
                <td class="compare-good">{good}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       WHAT SUCCESS LOOKS LIKE
  ═══════════════════════════════════════════════ -->
  <section class="success section section--dark">
    <div class="container">
      <div class="section-header section-header--light">
        <p class="badge">What Success Looks Like</p>
        <h2 style="color:white">Imagine your next placement season.</h2>
      </div>
      <div class="success-flow">
        <div class="success-q">
          <span class="success-q-mark">"</span>
          Tell me about a project you're proud of.
        </div>
        <div class="success-steps">
          {[
            'Instead of searching for the right answer...',
            'the student opens GitHub.',
            'Explains the architecture.',
            'Describes the challenges.',
            'Demonstrates the solution.',
            'Answers follow-up questions confidently.',
          ].map((s, i) => (
            <div class="success-step">
              <span class="success-step-n">{String(i + 1).padStart(2, '0')}</span>
              <span>{s}</span>
            </div>
          ))}
        </div>
        <p class="success-note">That's a very different interview. And it starts months before the recruiter walks into campus. Not better certificates — better conversations between students and recruiters.</p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       OUR PHILOSOPHY
  ═══════════════════════════════════════════════ -->
  <section class="section">
    <div class="container" style="max-width:680px;text-align:center">
      <p class="badge">Our Philosophy</p>
      <h2>Technology changes.<br>Learning doesn't.</h2>
      <p style="margin-top:var(--space-sm)">People remember what they build. They remember what they solve. And employers hire people who can demonstrate capability, not just completion.</p>
      <blockquote class="cg-pull-quote">"Will this help a student perform better during an interview?" If the answer is no, it doesn't belong in the program.</blockquote>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       FAQ
  ═══════════════════════════════════════════════ -->
  <section class="faq section section--tinted">
    <div class="container" style="max-width:760px">
      <div class="section-header">
        <p class="badge">Frequently Asked Questions</p>
        <h2>Let's answer the practical stuff.</h2>
      </div>
      <div class="faq-list">
        {[
          { q: 'Can the programs be customized for our curriculum?', a: "Absolutely. Every engagement is tailored around your department, academic calendar, batch size and learning objectives." },
          { q: 'Can faculty participate alongside students?', a: 'Yes. Many colleges choose a blended approach where faculty learn alongside students before independently delivering future cohorts.' },
          { q: 'Can these be credit-bearing courses?', a: 'Yes. Our Semester Takeover model is specifically designed to integrate with existing academic structures.' },
          { q: 'How large can a batch be?', a: "We've successfully delivered programs ranging from small specialized cohorts to large institutional batches. We'll recommend the best delivery model based on your student numbers." },
          { q: 'How quickly can a program begin?', a: 'Depending on scope, programs can often begin within a few weeks. For placement-focused cohorts, we work backwards from your placement calendar.' },
        ].map(item => (
          <details class="faq-item">
            <summary>{item.q}</summary>
            <p>{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       FINAL CTA
  ═══════════════════════════════════════════════ -->
  <section class="section">
    <div class="container" style="max-width:640px;text-align:center">
      <h2>Let's solve the right problem.</h2>
      <p style="margin:var(--space-sm) 0 var(--space-lg)">Maybe your priority is improving placements. Maybe it's modernizing the curriculum. Maybe it's preparing faculty for the AI era. Your students only get one placement season each year — let's make sure they're ready when opportunity arrives.</p>
      <div class="final-cta-actions">
        <a href="/contact" class="btn btn--primary">Book a Consultation</a>
        <a href="https://wa.me/919876656573?text=Hi%21+I%27d+like+to+discuss+an+AI+training+program+for+our+college." target="_blank" rel="noopener" class="btn btn--outline cg-wa-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp us instead
        </a>
      </div>
    </div>
  </section>

  </main>
  <Footer />
</BaseLayout>

<style>
  .section { padding: var(--space-2xl) 0; }
  .section--tinted { background: var(--color-surface); }
  .section--dark   { background: var(--color-dark); }
  .section-header  { text-align: center; margin-bottom: var(--space-xl); max-width: 640px; margin-inline: auto; }
  .section-header .badge { margin-bottom: var(--space-sm); }
  .section-header h2 { margin: var(--space-xs) 0 var(--space-sm); }
  .section-header--light p { color: rgba(255,255,255,0.65); }

  /* Hero */
  .cg-hero { padding: var(--space-2xl) 0 var(--space-xl); border-bottom: 1px solid var(--color-border); }
  .hero-inner { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-xl); align-items: center; }
  .hero-text .badge { margin-bottom: var(--space-md); }
  .hero-text h1 { margin-bottom: var(--space-md); }
  .hero-sub { font-size: 1.05rem; max-width: 480px; margin-bottom: var(--space-lg); }
  .hero-actions { display: flex; gap: var(--space-sm); flex-wrap: wrap; }

  /* Trusted-by strip */
  .trusted-strip { margin-top: var(--space-xl); padding-top: var(--space-lg); border-top: 1px solid var(--color-border); display: flex; align-items: center; gap: var(--space-md); flex-wrap: wrap; }
  .trusted-label { font-family: var(--font-heading); font-size: 0.72rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-body); flex-shrink: 0; }
  .trusted-names { display: flex; align-items: center; gap: var(--space-sm); flex-wrap: wrap; font-family: var(--font-heading); font-size: 0.9rem; font-weight: 600; color: var(--color-dark); }
  .trusted-dot { color: var(--color-accent); }

  /* Placement dashboard visual (same pattern as corporate-training) */
  .training-dash { background: #0d1117; border: 1px solid rgba(255,255,255,0.1); border-radius: 16px; overflow: hidden; box-shadow: 0 30px 60px rgba(0,0,0,0.3); animation: dashIn 0.7s ease 0.3s both; }
  @keyframes dashIn { from { opacity:0; transform:translateY(16px); } to { opacity:1; transform:translateY(0); } }
  .td-topbar { background: #161b22; padding: 10px 14px; display: flex; align-items: center; gap: 8px; border-bottom: 1px solid rgba(255,255,255,0.06); }
  .td-logo-dot { width: 18px; height: 18px; border-radius: 5px; background: var(--color-primary); flex-shrink: 0; }
  .td-title { font-size: 0.78rem; font-weight: 600; color: rgba(255,255,255,0.7); flex: 1; }
  .td-live { display: flex; align-items: center; gap: 5px; font-size: 0.62rem; font-weight: 700; color: #10b981; }
  .td-live-dot { width: 6px; height: 6px; border-radius: 50%; background: #10b981; animation: livePulse 2s infinite; }
  @keyframes livePulse { 0%,100% { box-shadow:0 0 0 2px rgba(16,185,129,0.2); } 50% { box-shadow:0 0 0 5px rgba(16,185,129,0.05); } }
  .td-body { padding: 14px; display: flex; flex-direction: column; gap: 12px; }
  .td-stats { display: grid; grid-template-columns: repeat(3,1fr); gap: 8px; }
  .tds { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06); border-radius: 8px; padding: 10px; text-align: center; }
  .tds-num { font-family: var(--font-heading); font-size: 1.3rem; font-weight: 800; color: white; line-height: 1; }
  .tds-num span { font-size: 0.85rem; color: var(--color-accent); }
  .tds-label { font-size: 0.6rem; color: rgba(255,255,255,0.35); margin-top: 3px; }
  .td-section-label { font-size: 0.6rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: rgba(255,255,255,0.3); }
  .td-cohorts { display: flex; flex-direction: column; gap: 6px; }
  .tdc-row { display: flex; align-items: center; gap: 7px; }
