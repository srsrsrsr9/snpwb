---
import BaseLayout from '../layouts/BaseLayout.astro'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'
---

<BaseLayout title="AI Consulting & Implementation" description="SnapSkill helps enterprises implement AI that delivers measurable business outcomes — from strategy through production.">
  <Nav />
  <main>

  <!-- ── Hero ──────────────────────────────────────── -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-content">
        <p class="badge badge--accent">AI Consulting · Implementation · Capability Building</p>
        <h1>AI that ships.<br><span class="text-primary">Not just slides.</span></h1>
        <p class="hero-sub">Most AI pilots die in the boardroom. We take them to production — with the business outcomes to prove it.</p>
        <div class="hero-actions">
          <a href="/contact" class="btn btn--primary">Start a conversation</a>
          <a href="/blog" class="btn btn--outline">Read our insights</a>
        </div>
        <div class="hero-proof">
          <div class="proof-item">
            <strong>73%</strong>
            <span>of AI pilots never reach production</span>
          </div>
          <div class="proof-divider"></div>
          <div class="proof-item">
            <strong>We fix that.</strong>
            <span>Strategy → Build → Adoption</span>
          </div>
        </div>
      </div>
      <div class="hero-visual" aria-hidden="true">
        <!-- 73% stat overlay -->
        <div class="stat-overlay">
          <strong>73<span>%</span></strong>
          <p>of AI pilots<br>never ship</p>
        </div>

        <!-- Main pipeline card -->
        <div class="pipeline-card">
          <p class="pipeline-label">Implementation Pipeline</p>

          <div class="pipeline-steps">
            <div class="pip-step pip-done"><span class="pip-icon">&#10003;</span><span class="pip-name">Discovery</span><span class="pip-status done">Done</span></div>
            <span class="pip-arrow">&rarr;</span>
            <div class="pip-step pip-done"><span class="pip-icon">&#10003;</span><span class="pip-name">Data Audit</span><span class="pip-status done">Done</span></div>
            <span class="pip-arrow">&rarr;</span>
            <div class="pip-step pip-active"><span class="pip-icon">&#9881;</span><span class="pip-name">Build</span><span class="pip-status active">In progress</span></div>
            <span class="pip-arrow">&rarr;</span>
            <div class="pip-step"><span class="pip-icon">&#9675;</span><span class="pip-name">Production</span><span class="pip-status">Week 8</span></div>
          </div>

          <div class="pipeline-metrics">
            <div class="pm-row"><span>Pilot &rarr; Production rate</span><strong>85%</strong></div>
            <div class="pm-row"><span>Industry average</span><strong class="muted">27%</strong></div>
          </div>

          <div class="pipeline-checks">
            <div class="pcheck"><span class="pcheck-dot done"></span> Data pipeline validated: <strong>2 issues resolved</strong></div>
            <div class="pcheck"><span class="pcheck-dot done"></span> Model accuracy <strong>91.4%</strong>: target met</div>
            <div class="pcheck"><span class="pcheck-dot done"></span> Stakeholder sign-off received</div>
          </div>

          <div class="deploy-row">
            <span class="deploy-check">&#10003;</span>
            <span class="deploy-text">Production<br>deployed</span>
            <span class="week-badge">Week 10</span>
          </div>
        </div>
      </div>
    </div>
    <div class="hero-gradient" aria-hidden="true"></div>
  </section>

  <!-- ── The Problem ───────────────────────────────── -->
  <section class="problem section">
    <div class="container problem-inner">
      <div class="problem-stats">
        <div class="big-stat">
          <strong>88<span>%</span></strong>
          <p>of AI proof-of-concepts<br>never reach production</p>
          <cite>S&P Global Market Intelligence, 2025</cite>
        </div>
        <div class="small-stats">
          <div class="sm-stat">
            <strong>42<span>%</span></strong>
            <p>of companies abandoned AI initiatives in 2025</p>
          </div>
          <div class="sm-stat">
            <strong>33<span>x</span></strong>
            <p>POCs launched for every 4 that reach production</p>
          </div>
        </div>
      </div>
      <div class="problem-text">
        <p class="badge">The Problem</p>
        <h2>Your AI initiative is probably in trouble. Here's why.</h2>
        <p>Board pressure creates pilots born from FOMO, not ROI. Technical teams optimise F1-scores while integration tasks sit untouched. Nobody's talking to compliance, IT, or the people who'll actually use the thing.</p>
        <p>By the time someone asks "when do we go live?" — the integration challenges, data governance issues, and user resistance surface all at once. The project gets quietly deprioritised. Sound familiar?</p>
        <p>The 5–30% of AI projects that succeed share one thing: they treat implementation as an organisational challenge, not a technical one.</p>
        <a href="/blog/why-ai-pilots-fail" class="service-link">Read the full analysis &rarr;</a>
      </div>
    </div>
  </section>

  <!-- ── Services ──────────────────────────────────── -->
  <section class="services section">
    <div class="container">
      <div class="section-header">
        <p class="badge">What We Do</p>
        <h2>End-to-end AI delivery</h2>
        <p>From identifying the right problems to embedding AI into how your team actually works.</p>
      </div>

      <div class="services-grid">
        <div class="service-card service-card--featured">
          <div class="service-icon" aria-hidden="true">⚙️</div>
          <h3>AI Implementation</h3>
          <p>We take your highest-value use cases from POC to production — with integrations, governance, and change management built in from day one.</p>
          <!-- Learn more link hidden until page is ready -->
        </div>
        <div class="service-card">
          <div class="service-icon" aria-hidden="true">🎯</div>
          <h3>AI Strategy & Consulting</h3>
          <p>Identify which AI bets will move your P&L. We audit your data readiness, prioritise use cases, and build a roadmap leadership actually believes in.</p>
          <!-- Learn more link hidden until page is ready -->
        </div>
        <div class="service-card">
          <div class="service-icon" aria-hidden="true">🧠</div>
          <h3>Capability Building</h3>
          <p>Upskill your teams to sustain AI initiatives long after the engagement ends. Custom programs for executives, PMs, and practitioners.</p>
          <!-- Learn more link hidden until page is ready -->
        </div>
      </div>
    </div>
  </section>

  <!-- ── Products ───────────────────────────────────── -->
  <section class="products section section--tinted">
    <div class="container">
      <div class="section-header">
        <p class="badge">Our Products</p>
        <h2>Built for scale</h2>
        <p>Platforms that embed learning and AI capability directly into how your organisation works.</p>
      </div>
      <div class="products-grid">
        <a href="/lms" class="product-card">
          <div class="product-icon" aria-hidden="true">📚</div>
          <div>
            <h3>SnapSkill LMS</h3>
            <p>AI-powered learning management system built for enterprise upskilling programs.</p>
            <span class="service-link">Explore platform →</span>
          </div>
        </a>
        <a href="/corporate-training" class="product-card">
          <div class="product-icon" aria-hidden="true">🏢</div>
          <div>
            <h3>Corporate AI Training</h3>
            <p>Custom training programs designed around your team's actual workflows and tools.</p>
            <span class="service-link">See programs →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ── Why SnapSkill ──────────────────────────────── -->
  <section class="why section section--dark">
    <div class="container">
      <div class="section-header section-header--light">
        <p class="badge">Why SnapSkill</p>
        <h2 style="color:white">We've seen why pilots fail.<br>We know how to prevent it.</h2>
      </div>

      <div class="pillars-grid">
        {[
          { icon: '📊', title: 'Business-first thinking', body: 'Every engagement starts with the P&L impact, not the model architecture.' },
          { icon: '🔗', title: 'Integration by default', body: 'We design for your legacy systems, compliance stack, and real users from day one.' },
          { icon: '📈', title: 'Outcomes, not outputs', body: 'We track business KPIs — revenue, cost, time — not just technical accuracy metrics.' },
          { icon: '🤝', title: 'Knowledge transfer', body: 'Your teams own the AI, not us. We build internal capability as we deliver.' },
        ].map(p => (
          <div class="pillar">
            <div class="pillar-icon" aria-hidden="true">{p.icon}</div>
            <h3>{p.title}</h3>
            <p>{p.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CTA ───────────────────────────────────────── -->
  <section class="cta-section section">
    <div class="container">
      <div class="cta-box">
        <h2>Ready to move from pilot to production?</h2>
        <p>Let's start with an honest conversation about where your AI initiative stands — and what it would take to make it work.</p>
        <a href="/contact" class="btn btn--primary">Talk to us</a>
      </div>
    </div>
  </section>

  </main>
  <Footer />
</BaseLayout>

<style>
  .section { padding: var(--space-2xl) 0; }
  .section--dark   { background: var(--color-dark); }
  .section--tinted { background: var(--color-surface); }

  .section-header { text-align: center; margin-bottom: var(--space-xl); max-width: 560px; margin-inline: auto; }
  .section-header .badge { margin-bottom: var(--space-sm); }
  .section-header h2 { margin: var(--space-xs) 0 var(--space-sm); }
  .section-header--light p  { color: rgba(255,255,255,0.65); }

  /* Hero */
  .hero { position: relative; padding: var(--space-2xl) 0 var(--space-xl); overflow: hidden; }
  .hero-gradient {
    position: absolute; inset: 0;
    background: radial-gradient(ellipse 80% 60% at 70% 50%, rgba(0,123,255,0.07) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-inner { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-xl); align-items: center; position: relative; }
  .hero-content { position: relative; z-index: 2; }
  .hero-content .badge { margin-bottom: var(--space-md); }
  .hero-content h1 { margin-bottom: var(--space-md); }
  .hero-sub { font-size: 1.15rem; max-width: 460px; margin-bottom: var(--space-lg); }
  .hero-actions { display: flex; gap: var(--space-sm); flex-wrap: wrap; margin-bottom: var(--space-lg); }
  .hero-proof {
    display: flex; align-items: center; gap: var(--space-md);
    padding: var(--space-md); background: rgba(248,249,250,0.7);
    border-radius: var(--radius-md); border: 1px solid rgba(0,0,0,0.06);
  }
  .proof-item { display: flex; flex-direction: column; }
  .proof-item strong { font-family: var(--font-heading); font-size: 1.6rem; color: var(--color-primary); opacity: 0.85; }
  .proof-item span   { font-size: 0.8rem; color: var(--color-body); }
  .proof-divider     { width: 1px; height: 36px; background: rgba(0,0,0,0.08); flex-shrink: 0; }

  /* Hero visual — pipeline dashboard */
  .hero-visual { position: relative; }

  .stat-overlay {
    position: absolute; top: -10px; left: -10px; z-index: 2;
    background: #f0f4f8; border: 1px solid #dce3ea;
    border-radius: var(--radius-md); padding: var(--space-sm) var(--space-md);
    box-shadow: var(--shadow-sm);
  }
  .stat-overlay strong {
    font-family: var(--font-heading); font-size: 2rem; font-weight: 800;
    color: var(--color-primary); line-height: 1;
  }
  .stat-overlay strong span { font-size: 1.2rem; }
  .stat-overlay p { font-size: 0.72rem; color: var(--color-body); margin: 0; line-height: 1.3; }

  .pipeline-card {
    background: #111827; border-radius: var(--radius-lg);
    padding: var(--space-md) var(--space-md) var(--space-sm);
    color: rgba(255,255,255,0.85); position: relative;
    box-shadow: 0 12px 40px rgba(0,0,0,0.25);
  }
  .pipeline-label {
    font-size: 0.7rem; font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.08em; color: rgba(255,255,255,0.45); margin-bottom: var(--space-md);
    padding-left: 90px;
  }

  .pipeline-steps {
    display: flex; align-items: center; gap: 6px;
    margin-bottom: var(--space-md); flex-wrap: wrap;
  }
  .pip-step {
    display: flex; flex-direction: column; align-items: center; gap: 4px;
    background: rgba(255,255,255,0.06); border-radius: var(--radius-sm);
    padding: 8px 12px; min-width: 72px;
  }
  .pip-icon { font-size: 0.85rem; }
  .pip-name { font-size: 0.7rem; font-weight: 600; }
  .pip-status { font-size: 0.6rem; color: rgba(255,255,255,0.4); }
  .pip-status.done { color: #34d399; }
  .pip-status.active { color: var(--color-accent); }
  .pip-done { border: 1px solid rgba(52,211,153,0.3); }
  .pip-active { border: 1px solid rgba(255,195,0,0.4); background: rgba(255,195,0,0.08); }
  .pip-arrow { color: rgba(255,255,255,0.25); font-size: 0.8rem; }

  .pipeline-metrics {
    display: flex; flex-direction: column; gap: 6px;
    margin-bottom: var(--space-sm); padding: 0 4px;
  }
  .pm-row {
    display: flex; justify-content: space-between; align-items: center;
    font-size: 0.75rem; color: rgba(255,255,255,0.5);
  }
  .pm-row strong { color: white; font-size: 0.85rem; }
  .pm-row strong.muted { color: rgba(255,255,255,0.35); }

  .pipeline-checks {
    display: flex; flex-direction: column; gap: 5px;
    margin-bottom: var(--space-sm); padding: 0 4px;
  }
  .pcheck { font-size: 0.72rem; color: rgba(255,255,255,0.55); display: flex; align-items: center; gap: 6px; }
  .pcheck strong { color: rgba(255,255,255,0.8); }
  .pcheck-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; background: rgba(255,255,255,0.2); }
  .pcheck-dot.done { background: #34d399; }

  .deploy-row {
    display: flex; align-items: center; gap: var(--space-sm);
    background: rgba(255,255,255,0.05); border-radius: var(--radius-sm);
    padding: 8px 12px; margin-top: var(--space-xs);
  }
  .deploy-check {
    width: 24px; height: 24px; border-radius: 50%;
    background: var(--color-primary); color: white;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.75rem; font-weight: 700; flex-shrink: 0;
  }
  .deploy-text { font-size: 0.72rem; line-height: 1.3; color: rgba(255,255,255,0.6); }
  .week-badge {
    margin-left: auto; font-family: var(--font-heading);
    font-size: 0.75rem; font-weight: 700; color: var(--color-dark);
    background: var(--color-accent); padding: 4px 12px;
    border-radius: 100px; white-space: nowrap;
    box-shadow: 0 0 0 3px rgba(255,195,0,0.3);
  }

  /* Services */
  .services-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-md); }
  .service-card { padding: var(--space-lg); border-radius: var(--radius-lg); border: 1px solid var(--color-border); background: white; transition: var(--transition); }
  .service-card:hover { box-shadow: var(--shadow-md); transform: translateY(-3px); }
  .service-card--featured { background: linear-gradient(135deg, var(--color-dark) 0%, #151d4a 100%); border-color: transparent; }
  .service-card--featured h3 { color: var(--color-accent); }
  .service-card--featured p  { color: rgba(255,255,255,0.72); }
  .service-card--featured .service-link { color: white; }
  .service-icon { font-size: 2rem; margin-bottom: var(--space-sm); }
  .service-card h3 { margin-bottom: var(--space-sm); }
  .service-card p  { font-size: 0.93rem; margin-bottom: var(--space-md); }
  .service-link { font-size: 0.9rem; font-weight: 600; color: var(--color-primary); }

  /* Products */
  .products-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-md); }
  .product-card {
    display: flex; gap: var(--space-md); align-items: flex-start;
    padding: var(--space-lg); border-radius: var(--radius-lg);
    border: 2px solid var(--color-border); background: white;
    text-decoration: none; transition: var(--transition);
  }
  .product-card:hover { border-color: var(--color-primary); box-shadow: var(--shadow-md); transform: translateY(-2px); }
  .product-icon { font-size: 2.5rem; flex-shrink: 0; }
  .product-card h3 { margin-bottom: var(--space-xs); color: var(--color-dark); }
  .product-card p  { font-size: 0.93rem; margin-bottom: var(--space-sm); }

  /* Why */
  .pillars-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-md); }
  .pillar { padding: var(--space-md); border-radius: var(--radius-md); background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08); }
  .pillar-icon { font-size: 1.75rem; margin-bottom: var(--space-sm); }
  .pillar h3   { color: white; font-size: 1rem; margin-bottom: var(--space-xs); }
  .pillar p    { font-size: 0.9rem; color: rgba(255,255,255,0.6); margin: 0; }

  /* Problem */
  .problem-inner { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-xl); align-items: start; }
  .big-stat { margin-bottom: var(--space-md); }
  .big-stat strong {
    font-family: var(--font-heading); font-size: clamp(4rem, 8vw, 6rem);
    font-weight: 800; color: var(--color-primary); line-height: 1;
  }
  .big-stat strong span { font-size: 0.5em; }
  .big-stat p { font-size: 0.95rem; font-weight: 600; color: var(--color-dark); margin: var(--space-xs) 0 var(--space-2xs); }
  .big-stat cite { font-size: 0.75rem; font-style: normal; color: var(--color-body); }
  .small-stats { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-md); }
  .sm-stat { padding: var(--space-md); border: 1px solid var(--color-border); border-radius: var(--radius-md); }
  .sm-stat strong { font-family: var(--font-heading); font-size: 1.75rem; font-weight: 800; color: var(--color-dark); display: block; }
  .sm-stat strong span { font-size: 0.7em; }
  .sm-stat p { font-size: 0.8rem; margin: 0; }
  .problem-text .badge { margin-bottom: var(--space-sm); }
  .problem-text h2 { margin-bottom: var(--space-md); }
  .problem-text p { font-size: 0.95rem; margin-bottom: var(--space-sm); }
  .problem-text .service-link { font-size: 0.9rem; font-weight: 600; color: var(--color-primary); }

  /* CTA */
  .cta-box { text-align: center; padding: var(--space-xl); border-radius: var(--radius-lg); background: var(--color-surface); border: 2px solid var(--color-border); max-width: 640px; margin: 0 auto; }
  .cta-box h2 { margin-bottom: var(--space-sm); }
  .cta-box p  { margin-bottom: var(--space-lg); max-width: 440px; margin-inline: auto; margin-bottom: var(--space-lg); }

  @media (max-width: 960px) {
    .hero-inner { grid-template-columns: 1fr; }
    .hero-visual { display: none; }
    .problem-inner { grid-template-columns: 1fr; }
    .services-grid { grid-template-columns: 1fr; }
    .pillars-grid  { grid-template-columns: repeat(2, 1fr); }
    .products-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 600px) {
    .pillars-grid { grid-template-columns: 1fr; }
    .hero-actions { flex-direction: column; }
  }
</style>
