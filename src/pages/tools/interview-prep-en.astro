---
import BaseLayout from '../../layouts/BaseLayout.astro'
import Nav from '../../components/Nav.astro'
import Footer from '../../components/Footer.astro'
---

<BaseLayout
  title="Interview Confidence Coach"
  description="Practice interview English out loud, get honest feedback, build real confidence."
  fonts={["https://fonts.googleapis.com/css2?family=Baloo+2:wght@500;700;800&family=Caveat:wght@600;700&family=Inter:wght@400;500;600;700&family=Lora:ital@1&display=swap"]}
>
  <Nav />
  <main>

<div class="wrap">
  <p class="lang-toggle"><a href="/tools/interview-prep">Hinglish version →</a></p>

<section class="hero">
    <span class="kicker">Nerves out. Confidence in. 😤</span>
    <h1 class="title">Practice out loud.<br><span>Fumble here</span>, not in the interview.</h1>
    <p class="sub">Pick a question, answer like the room's watching, and get honest (funny) feedback on your English and confidence — no judgement, just practice.</p>
  </section>

  <div class="streakbar">
    <div class="stat">Attempted: <b id="statAttempts">0</b></div>
    <div class="stat">Best score: <b id="statBest">0</b></div>
    <div class="stat">Average: <b id="statAvg">–</b></div>
  </div>

  <div class="stage" id="pickerStage">
    <div class="cat-grid" id="catGrid"></div>
  </div>

  <div class="stage" id="practiceStage" style="display:none;">
    <div class="panel">
      <span class="tag" id="catTag">Category</span>
      <div class="coach">
        <div class="avatar">🎤</div>
        <div class="bubble" id="coachLine">Take a breath. Speak like you already got the job.</div>
      </div>

      <button class="lesson-toggle no-print" id="lessonToggle">🎓 <span id="lessonToggleText">60-second lesson</span> <span class="arrow">▾</span></button>
      <div class="lesson-box" id="lessonBox"></div>

      <div class="question-box">
        <div class="qnum" id="qnum">Question 1 of 5</div>
        <div id="qtext">Loading...</div>
      </div>

      <div class="timerrow">
        <span id="timerDisplay">⏱ 00:00</span>
        <button class="mic-btn" id="micBtn">🎙 Speak instead of type</button>
      </div>

      <textarea id="answerBox" placeholder="Type — or speak — your answer here. Aim for 40-100 words, like you're actually talking to the interviewer."></textarea>
      <div class="wordcount" id="wordCount">0 words</div>

      <div class="nav-row">
        <button class="btn ghost" id="backToCats">← Change topic</button>
        <button class="btn ghost" id="skipBtn">Skip question →</button>
        <button class="btn primary" id="submitBtn">Get feedback ✅</button>
      </div>

      <div class="feedback" id="feedbackBox">
        <div class="meter-row">
          <div class="meter-label" id="scoreLabel">0/100</div>
          <div class="meter-wrap">
            <div class="meter-track"><div class="meter-fill" id="meterFill"></div></div>
          </div>
        </div>
        <div class="verdict" id="verdictLine"></div>
        <div class="tips">
          <strong>Coach notes:</strong>
          <ul id="tipsList"></ul>
        </div>
        <div class="nav-row">
          <button class="btn ghost" id="retryBtn">↻ Try this one again</button>
          <button class="btn gold" id="nextQBtn">Next question →</button>
        </div>
      </div>
    </div>
  </div>

  <div class="cert-wrap" id="certWrap">
    <div class="certificate">
      <div class="cert-corner tl"></div>
      <div class="cert-corner tr"></div>
      <div class="cert-corner bl"></div>
      <div class="cert-corner br"></div>

      <svg class="cert-seal" viewBox="0 0 120 140" width="72" height="84" aria-hidden="true">
        <polygon class="cs-ribbon" points="40,78 40,133 60,119 80,133 80,78"></polygon>
        <circle class="cs-coin" cx="60" cy="54" r="42"></circle>
        <circle class="cs-ring" cx="60" cy="54" r="33"></circle>
        <path class="cs-check" d="M43 55 L55 67 L79 39"></path>
      </svg>

      <div class="cert-eyebrow">SnapSkill · Confidence Certified</div>
      <h2 class="cert-title">You spoke. You didn't freeze. 🎉</h2>
      <p class="cert-lead">This certifies that</p>
      <div class="cert-name" id="certName">You</div>
      <svg class="cert-swash" viewBox="0 0 220 20" width="180" height="16" aria-hidden="true">
        <path class="cert-swash-path" d="M4 13 Q 40 3, 80 11 T 160 9 T 216 5" fill="none" stroke-width="2.5" stroke-linecap="round"></path>
      </svg>
      <p class="cert-note" id="certNote">Average confidence score: 0/100 across 0 questions.</p>
      <p class="cert-note">Your nerves have officially left the chat.</p>

      <div class="cert-footer">
        <div class="cert-sig-block">
          <div class="cert-sig-script">SnapSkill</div>
          <div class="cert-sig-rule"></div>
          <div class="cert-sig-label">Placement Prep Coach</div>
        </div>
        <div class="cert-sig-block">
          <div class="cert-sig-script" id="certDate"></div>
          <div class="cert-sig-rule"></div>
          <div class="cert-sig-label">Date</div>
        </div>
      </div>
    </div>
    <div class="nav-row" style="justify-content:center;margin-top:18px;">
      <button class="btn primary no-print" id="downloadCertBtn">⬇ Download certificate</button>
      <button class="btn ghost no-print" id="closeCertBtn">Back to practice</button>
    </div>
    <div class="share-love no-print">
      <p>💛 Know someone else prepping for placements? Send them here instead of letting them freeze up cold.</p>
      <div class="share-row">
        <a class="share-btn wa" id="waShareBtn" href="#" target="_blank" rel="noopener">📲 Share on WhatsApp</a>
        <button class="share-btn" id="copyLinkBtn">🔗 Copy link</button>
      </div>
    </div>
  </div>
</div>


  </main>
  <Footer />
</BaseLayout>

<style is:global>

  :root{
    --ink:#12163B;
    --sun:#FFC93C;
    --coral:#FF5D5D;
    --mint:#4FD8A8;
    --cream:#FFF8ED;
    --charcoal:#1F2430;
    --line:#E7E1D2;
    --shadow: 6px 6px 0 var(--ink);
  }
  *{box-sizing:border-box;}
  body{margin:0;background:var(--cream);color:var(--charcoal);font-family:'Inter',sans-serif;min-height:100vh;}
  body::before{
    content:"";position:fixed;inset:0;pointer-events:none;z-index:0;
    background-image:radial-gradient(var(--ink) 1px, transparent 1px);
    background-size:18px 18px;opacity:0.05;
  }
  .wrap{max-width:920px;margin:0 auto;padding:0 20px;position:relative;z-index:1;}
  header.site{padding:22px 0 10px;}
  .brandrow{display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;}
  .brand{display:flex;align-items:center;gap:10px;font-family:'Baloo 2',sans-serif;font-weight:800;font-size:1.3rem;color:var(--ink);text-decoration:none;}
  .brand .dot{width:12px;height:12px;background:var(--coral);border-radius:50%;display:inline-block;}
  .backlink{font-size:0.85rem;font-weight:600;color:var(--ink);opacity:0.7;text-decoration:none;border-bottom:2px solid var(--ink);}
  .backlink:hover{opacity:1;}

  .hero{padding:22px 0 6px;text-align:center;}
  .kicker{display:inline-block;font-family:'Caveat',cursive;font-size:1.5rem;color:var(--coral);transform:rotate(-2deg);}
  h1.title{font-family:'Baloo 2',sans-serif;font-weight:800;font-size:clamp(1.9rem,5.5vw,3rem);line-height:1.08;margin:6px 0 10px;color:var(--ink);}
  h1.title span{background:linear-gradient(180deg,transparent 60%, var(--sun) 60%);padding:0 4px;}
  .sub{font-size:1.02rem;max-width:560px;margin:0 auto 8px;color:#43485c;}

  .streakbar{
    display:flex;justify-content:center;gap:18px;flex-wrap:wrap;margin:22px 0 8px;font-family:'Baloo 2',sans-serif;font-weight:700;font-size:0.9rem;
  }
  .stat{background:#fff;border:2px solid var(--ink);border-radius:12px;padding:8px 16px;box-shadow:3px 3px 0 var(--ink);}
  .stat b{color:var(--coral);}

  .stage{margin-top:22px;}

  /* CATEGORY PICKER */
  .cat-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:16px;margin-top:18px;}
  .cat-card{
    background:#fff;border:2.5px solid var(--ink);border-radius:16px;padding:20px;cursor:pointer;
    box-shadow:var(--shadow);transition:transform .12s ease;text-align:left;
  }
  .cat-card:hover{transform:translate(-2px,-2px);}
  .cat-card .emoji{font-size:1.8rem;}
  .cat-card h3{font-family:'Baloo 2',sans-serif;margin:8px 0 4px;font-size:1.1rem;color:var(--ink);}
  .cat-card p{margin:0;font-size:0.85rem;color:#5a5f74;}

  /* PRACTICE PANEL */
  .panel{
    background:#fff;border:2.5px solid var(--ink);border-radius:18px;box-shadow:var(--shadow);
    padding:26px 26px 22px;position:relative;margin-top:6px;
  }
  .panel .tag{
    position:absolute;top:-16px;left:22px;background:var(--coral);color:#fff;
    font-family:'Baloo 2',sans-serif;font-weight:700;font-size:0.8rem;padding:5px 14px;border-radius:999px;border:2px solid var(--ink);
  }
  .coach{display:flex;gap:12px;align-items:flex-start;margin:14px 0 18px;}
  .coach .avatar{
    flex:0 0 auto;width:42px;height:42px;border-radius:50%;background:var(--sun);
    border:2px solid var(--ink);display:flex;align-items:center;justify-content:center;font-size:1.3rem;
  }
  .coach .bubble{
    background:var(--cream);border:2px solid var(--ink);border-radius:14px 14px 14px 2px;
    padding:10px 14px;font-family:'Caveat',cursive;font-size:1.25rem;line-height:1.25;color:var(--ink);
  }

  .question-box{
    background:var(--ink);color:#fff;border-radius:14px;padding:20px 22px;font-family:'Baloo 2',sans-serif;
    font-size:1.15rem;font-weight:600;margin-bottom:16px;position:relative;
  }
  .question-box .qnum{font-size:0.75rem;font-weight:700;color:var(--sun);text-transform:uppercase;letter-spacing:1px;margin-bottom:6px;}

  .timerrow{display:flex;align-items:center;gap:10px;margin-bottom:10px;font-family:'Baloo 2',sans-serif;font-weight:700;color:var(--coral);}
  .mic-btn{
    border:2.5px solid var(--ink);background:#fff;border-radius:999px;padding:8px 16px;cursor:pointer;
    font-family:'Baloo 2',sans-serif;font-weight:700;font-size:0.85rem;box-shadow:3px 3px 0 var(--ink);
  }
  .mic-btn.listening{background:var(--coral);color:#fff;}

  textarea#answerBox{
    width:100%;min-height:130px;padding:14px;border:2px solid var(--line);border-radius:12px;
    font-family:'Inter',sans-serif;font-size:0.98rem;background:#fffdf8;resize:vertical;
  }
  textarea#answerBox:focus{outline:none;border-color:var(--coral);}

  .wordcount{font-size:0.8rem;color:#8a8f9f;margin-top:6px;text-align:right;}

  .nav-row{display:flex;justify-content:space-between;margin-top:20px;gap:10px;flex-wrap:wrap;}
  button.btn{
    font-family:'Baloo 2',sans-serif;font-weight:700;font-size:0.95rem;cursor:pointer;
    border:2.5px solid var(--ink);border-radius:12px;padding:11px 22px;background:#fff;color:var(--ink);
    box-shadow:4px 4px 0 var(--ink);transition:transform .1s ease;
  }
  button.btn:active{transform:translate(2px,2px);box-shadow:2px 2px 0 var(--ink);}
  button.btn.primary{background:var(--coral);color:#fff;}
  button.btn.gold{background:var(--sun);color:var(--ink);}
  button.btn.ghost{background:none;box-shadow:none;}
  button.btn:disabled{opacity:0.35;cursor:not-allowed;box-shadow:none;}

  /* FEEDBACK */
  .feedback{margin-top:22px;border-top:2px dashed var(--line);padding-top:20px;display:none;}
  .meter-row{display:flex;align-items:center;gap:16px;margin-bottom:14px;flex-wrap:wrap;}
  .meter-wrap{flex:1;min-width:180px;}
  .meter-track{background:#eee;border:2px solid var(--ink);border-radius:999px;height:22px;overflow:hidden;}
  .meter-fill{height:100%;background:linear-gradient(90deg,var(--coral),var(--sun),var(--mint));width:0%;transition:width .6s ease;}
  .meter-label{font-family:'Baloo 2',sans-serif;font-weight:800;font-size:1.6rem;color:var(--ink);white-space:nowrap;}
  .verdict{font-family:'Caveat',cursive;font-size:1.5rem;color:var(--coral);margin:0 0 10px;}
  .tips{background:var(--cream);border:2px solid var(--line);border-radius:12px;padding:14px 18px;}
  .tips ul{margin:6px 0 0;padding-left:20px;}
  .tips li{margin-bottom:6px;font-size:0.92rem;}

  /* CERTIFICATE */
  .cert-wrap{display:none; text-align:center; margin-top:30px;}
  .certificate{
    position:relative; background:var(--cream); border:2px solid var(--ink); border-radius:4px;
    padding:46px 42px 34px; max-width:560px; margin:0 auto; font-family:'Inter',sans-serif;
    box-shadow:0 1px 2px rgba(18,22,59,0.08), 0 24px 48px rgba(18,22,59,0.12);
    -webkit-print-color-adjust:exact; print-color-adjust:exact;
  }
  .certificate::before{
    content:''; position:absolute; inset:9px; border:1px solid var(--ink); opacity:0.32; border-radius:2px; pointer-events:none;
  }
  .cert-corner{position:absolute; width:20px; height:20px; pointer-events:none;}
  .cert-corner.tl{top:15px; left:15px; border-top:3px solid var(--ink); border-left:3px solid var(--ink);}
  .cert-corner.tr{top:15px; right:15px; border-top:3px solid var(--ink); border-right:3px solid var(--ink);}
  .cert-corner.bl{bottom:15px; left:15px; border-bottom:3px solid var(--ink); border-left:3px solid var(--ink);}
  .cert-corner.br{bottom:15px; right:15px; border-bottom:3px solid var(--ink); border-right:3px solid var(--ink);}

  /* QUICK LESSON */
  .lesson-toggle{
    display:inline-flex;align-items:center;gap:8px;background:var(--mint);color:var(--ink);
    border:2px solid var(--ink);border-radius:999px;padding:7px 16px;font-family:'Baloo 2',sans-serif;
    font-weight:700;font-size:0.85rem;cursor:pointer;margin-bottom:14px;
  }
  .lesson-toggle .arrow{transition:transform .2s ease;}
  .lesson-toggle.open .arrow{transform:rotate(180deg);}
  .lesson-box{
    display:none;background:var(--cream);border:2px dashed var(--ink);border-radius:12px;
    padding:16px 18px;margin:-6px 0 18px;font-size:0.9rem;line-height:1.5;
  }
  .lesson-box.open{display:block;}
  .lesson-box h4{margin:0 0 8px;font-family:'Baloo 2',sans-serif;color:var(--coral);font-size:1rem;}
  .lesson-box .swap{background:#fff;border:1.5px solid var(--line);border-radius:8px;padding:8px 12px;margin-top:8px;font-size:0.85rem;}
  .lesson-box .swap .bad{color:#b03030;text-decoration:line-through;display:block;}
  .lesson-box .swap .good{color:#1c8a5f;font-weight:600;display:block;margin-top:4px;}

  /* SHARE THE LOVE */
  .share-love{
    background:#fff;border:2.5px solid var(--ink);border-radius:16px;padding:18px 22px;
    max-width:480px;margin:22px auto 0;box-shadow:4px 4px 0 var(--ink);text-align:center;
  }
  .share-love p{margin:0 0 12px;font-size:0.92rem;color:#43485c;}
  .share-love .share-row{display:flex;gap:10px;justify-content:center;flex-wrap:wrap;}
  .share-btn{
    font-family:'Baloo 2',sans-serif;font-weight:700;font-size:0.85rem;cursor:pointer;
    border:2px solid var(--ink);border-radius:10px;padding:8px 16px;background:var(--sun);color:var(--ink);
    text-decoration:none;display:inline-flex;align-items:center;gap:6px;
  }
  .share-btn.wa{background:#25D366;color:#0b3b1e;}

  footer.site{text-align:center;padding:40px 0 30px;font-size:0.82rem;color:#8a8f9f;}

  @media print{
    body::before{display:none;}
    header.site,.hero,.streakbar,.cat-grid,.panel,footer.site{display:none !important;}
    .cert-wrap{display:block !important;margin-top:0;}
  }


  .lang-toggle {
    text-align: right;
    margin: 0 0 -6px;
  }
  .lang-toggle a {
    font-family: 'Baloo 2', sans-serif;
    font-weight: 700;
    font-size: 0.82rem;
    color: var(--coral);
    text-decoration: none;
    border-bottom: 2px solid var(--coral);
  }
  .lang-toggle a:hover { opacity: 0.75; }
  @media print { .lang-toggle { display: none !important; } }
</style>

<script is:inline>

(function(){
  const categories = [
    {id:'intro', emoji:'👋', name:'Tell Me About Yourself', desc:'The one question that decides the first impression.'},
    {id:'strengths', emoji:'💪', name:'Strengths & Weaknesses', desc:'Sound honest, not like a LinkedIn post.'},
    {id:'why', emoji:'🎯', name:'Why Should We Hire You', desc:'Your highlight reel, without sounding like a trailer voiceover.'},
    {id:'behavioral', emoji:'🧩', name:'Behavioral Questions', desc:'Tell a story. HR loves a good story.'},
    {id:'tricky', emoji:'🌶️', name:'Tricky HR Curveballs', desc:'Salary, gaps, "where do you see yourself" — the spicy stuff.'}
  ];

  const questionBank = {
    intro: [
      "Tell me about yourself.",
      "Walk me through your resume in under two minutes.",
      "What does a typical day in your life look like right now?",
      "How would your best friend describe you in three words — and why?",
      "What's one thing about you that isn't on your resume?"
    ],
    strengths: [
      "What is your greatest strength?",
      "What is your biggest weakness, and what are you doing about it?",
      "Describe a time you failed at something. What did you learn?",
      "What's a skill you're actively trying to improve right now?",
      "How do you handle criticism from a manager or professor?"
    ],
    why: [
      "Why should we hire you over other candidates?",
      "What makes you the right fit for this role?",
      "What can you bring to this team in the first 90 days?",
      "What sets you apart from other freshers applying for this job?",
      "Why do you want to work in this industry?"
    ],
    behavioral: [
      "Tell me about a time you worked in a team to solve a problem.",
      "Describe a situation where you disagreed with someone and how you handled it.",
      "Tell me about a time you had to learn something new very quickly.",
      "Describe a project you're genuinely proud of.",
      "Tell me about a time you missed a deadline. What happened?"
    ],
    tricky: [
      "Where do you see yourself in five years?",
      "Why is there a gap in your education or work history?",
      "What are your salary expectations?",
      "Why did you choose this college or course?",
      "Are you interviewing anywhere else? How does this role compare?"
    ]
  };

  const lessons = {
    intro: {
      title:"The 3-part self-intro formula",
      body:`<p>Structure beats vocabulary here. Use: <strong>Present</strong> (what you're doing now) → <strong>Past</strong> (the relevant bit of your journey) → <strong>Future</strong> (why this role, specifically).</p>
        <div class="swap"><span class="bad">I am a hardworking, dedicated final-year student who wants to grow.</span><span class="good">I'm finishing my B.Tech in CS this year. I've spent the last year building small data projects, and I'm looking for a role where I can turn that into real analyst work.</span></div>`
    },
    strengths: {
      title:"Weaknesses: name it, then fix it",
      body:`<p>Every interviewer has heard "I'm a perfectionist" four hundred times. Name a real, small weakness and immediately show what you're doing about it — that's the actual answer they're listening for.</p>
        <div class="swap"><span class="bad">My weakness is I'm a perfectionist.</span><span class="good">I used to over-prepare for small presentations and burn hours on it. I now time-box prep to 2 hours max — it's made me faster without losing quality.</span></div>`
    },
    why: {
      title:"Answer their need, not your résumé",
      body:`<p>"Why should we hire you" isn't "list your skills again" — it's "connect your skills to what this specific role needs." Reread the job post before you answer.</p>
        <div class="swap"><span class="bad">I am hardworking, a fast learner, and a team player.</span><span class="good">You need someone who can handle messy data fast — I've done that with 3 college projects, including one under a 48-hour hackathon deadline.</span></div>`
    },
    behavioral: {
      title:"STAR: the classic story formula",
      body:`<p><strong>Situation</strong> (context) → <strong>Task</strong> (what needed doing) → <strong>Action</strong> (what YOU did) → <strong>Result</strong> (the outcome, ideally with a number). Most behavioral questions are really just asking for a STAR story.</p>`
    },
    tricky: {
      title:"Handling the spicy ones",
      body:`<p>Salary question: give a researched range, not a single number, and add that it's flexible for the right role. "Where do you see yourself in 5 years": show ambition tied to growing <em>within</em> this kind of role, not sounding like you'll leave in 6 months.</p>`
    }
  };

  const coachLinesIntro = [
    "Take a breath. Speak like you already got the job.",
    "Confidence is 60% tone, 40% words. Attack both.",
    "No need for fancy words — clear beats clever, every time.",
    "Pretend I'm the strictest HR you've met. Convince me anyway.",
    "Remember: pauses are fine. Silence is not the enemy, mumbling is."
  ];

  let currentCat = null;
  let currentQIndex = 0;
  let currentQuestionOrder = [];
  let timerSeconds = 0;
  let timerInterval = null;
  let recognizing = false;
  let recognition = null;

  const scores = [];

  function shuffle(arr){
    const a = arr.slice();
    for(let i=a.length-1;i>0;i--){
      const j = Math.floor(Math.random()*(i+1));
      [a[i],a[j]] = [a[j],a[i]];
    }
    return a;
  }

  function renderCatGrid(){
    const grid = document.getElementById('catGrid');
    grid.innerHTML = categories.map(c=>`
      <div class="cat-card" data-cat="${c.id}">
        <div class="emoji">${c.emoji}</div>
        <h3>${c.name}</h3>
        <p>${c.desc}</p>
      </div>
    `).join('');
    grid.querySelectorAll('[data-cat]').forEach(el=>{
      el.addEventListener('click', ()=> startCategory(el.dataset.cat));
    });
  }

  function startCategory(catId){
    currentCat = categories.find(c=>c.id===catId);
    currentQuestionOrder = shuffle(questionBank[catId]);
    currentQIndex = 0;
    document.getElementById('pickerStage').style.display = 'none';
    document.getElementById('practiceStage').style.display = 'block';
    document.getElementById('certWrap').style.display = 'none';
    loadQuestion();
    document.getElementById('practiceStage').scrollIntoView({behavior:'smooth'});
  }

  function loadQuestion(){
    document.getElementById('catTag').textContent = currentCat.emoji + ' ' + currentCat.name;
    document.getElementById('coachLine').textContent = coachLinesIntro[currentQIndex % coachLinesIntro.length];
    document.getElementById('qnum').textContent = `Question ${currentQIndex+1} of ${currentQuestionOrder.length}`;
    document.getElementById('qtext').textContent = currentQuestionOrder[currentQIndex];
    document.getElementById('answerBox').value = '';
    document.getElementById('wordCount').textContent = '0 words';
    document.getElementById('feedbackBox').style.display = 'none';
    resetTimer();

    const lesson = lessons[currentCat.id];
    document.getElementById('lessonToggleText').textContent = lesson.title;
    document.getElementById('lessonBox').innerHTML = `<h4>🎓 ${lesson.title}</h4>${lesson.body}`;
    document.getElementById('lessonBox').classList.add('open');
    document.getElementById('lessonToggle').classList.add('open');
  }

  document.getElementById('lessonToggle').addEventListener('click', ()=>{
    document.getElementById('lessonBox').classList.toggle('open');
    document.getElementById('lessonToggle').classList.toggle('open');
  });

  let timerStarted = false;
  function resetTimer(){
    clearInterval(timerInterval);
    timerSeconds = 0;
    timerStarted = false;
    document.getElementById('timerDisplay').textContent = '⏱ 00:00';
  }
  function startTimer(){
    timerInterval = setInterval(()=>{
      timerSeconds++;
      const m = String(Math.floor(timerSeconds/60)).padStart(2,'0');
      const s = String(timerSeconds%60).padStart(2,'0');
      document.getElementById('timerDisplay').textContent = `⏱ ${m}:${s}`;
    },1000);
  }
  function ensureTimerStarted(){
    if(!timerStarted){
      timerStarted = true;
      startTimer();
    }
  }

  document.getElementById('answerBox').addEventListener('input', (e)=>{
    ensureTimerStarted();
    const words = e.target.value.trim().split(/\s+/).filter(Boolean).length;
    document.getElementById('wordCount').textContent = words + ' words';
  });

  const fillerWords = ["um","uh","like","actually","basically","you know","kind of","sort of","stuff","things","very very"];
  const confidenceWords = ["led","achieved","improved","built","managed","created","increased","reduced","launched","won","solved","delivered","organized","designed"];

  function analyze(text){
    const words = text.trim().split(/\s+/).filter(Boolean);
    const wordCount = words.length;
    const lower = text.toLowerCase();

    let score = 50;
    const tips = [];

    // length scoring
    if(wordCount < 15){
      score -= 25;
      tips.push("That was quite short — it can come across as shy or like you're holding something back. Add 2-3 more concrete sentences.");
    } else if(wordCount >= 15 && wordCount < 40){
      score -= 8;
      tips.push("Add a bit more detail — one small example or number makes it land harder.");
    } else if(wordCount >= 40 && wordCount <= 130){
      score += 20;
      tips.push("Length was spot on — long enough to show substance, short enough that nobody zoned out.");
    } else {
      score -= 12;
      tips.push("That ran long — interviewers have other candidates waiting. Trim it to your strongest 2-3 points.");
    }

    // filler words
    let fillerHits = 0;
    fillerWords.forEach(f=>{
      const re = new RegExp('\\b'+f.replace(/[.*+?^${}()|[\]\\]/g,'\\$&')+'\\b','gi');
      const m = lower.match(re);
      if(m) fillerHits += m.length;
    });
    if(fillerHits === 0){
      score += 15;
      tips.push("Zero filler words spotted. Certified smooth talker energy.");
    } else if(fillerHits <= 2){
      score += 2;
      tips.push(`Caught ${fillerHits} filler word(s) like "um" or "basically" — barely noticeable, but cut them for extra polish.`);
    } else {
      score -= 15;
      tips.push(`${fillerHits} filler words in there — practice saying it again, slower, with confident pauses instead of "um".`);
    }

    // confidence / action words
    let actionHits = 0;
    confidenceWords.forEach(w=>{
      const re = new RegExp('\\b'+w+'\\b','gi');
      const m = lower.match(re);
      if(m) actionHits += m.length;
    });
    if(actionHits >= 2){
      score += 15;
      tips.push("Loved the action words — 'led', 'built', 'achieved' — that's exactly the HR dictionary.");
    } else if(actionHits === 1){
      score += 5;
      tips.push("One strong action word in there. Add one more concrete verb and it'll hit even harder.");
    } else {
      score -= 8;
      tips.push("No strong action verbs yet. Swap generic lines for 'I led/built/improved X, which resulted in Y'.");
    }

    // numbers / specifics
    if(/\d/.test(text)){
      score += 10;
      tips.push("Numbers detected — nice, specifics always beat vague claims.");
    } else {
      tips.push("Try adding one number — a percentage, a team size, a timeline. Specifics = credibility.");
    }

    // first person ownership
    const iCount = (lower.match(/\bi\b/g)||[]).length;
    if(iCount >= 2){
      score += 5;
    } else {
      score -= 5;
      tips.push("Make sure you're speaking as 'I', not 'we' throughout — this is your interview, own it.");
    }

    score = Math.max(5, Math.min(100, Math.round(score)));
    return {score, tips: tips.slice(0,5), wordCount, fillerHits, actionHits};
  }

  function verdictFor(score){
    if(score >= 80) return "Okay, HR's favourite candidate just entered the chat. 🔥";
    if(score >= 60) return "Solid! A little more polish and that offer letter is close. ✨";
    if(score >= 40) return "Decent start — bring a bit more confidence, you've got this. 💪";
    return "Let's try that again — no stress, this is exactly what practice is for. 😄";
  }

  document.getElementById('submitBtn').addEventListener('click', ()=>{
    const text = document.getElementById('answerBox').value.trim();
    if(!text){
      document.getElementById('answerBox').focus();
      document.getElementById('answerBox').style.borderColor = 'var(--coral)';
      return;
    }
    clearInterval(timerInterval);
    const result = analyze(text);
    scores.push(result.score);
    updateStats();

    document.getElementById('scoreLabel').textContent = result.score + '/100';
    document.getElementById('meterFill').style.width = result.score + '%';
    document.getElementById('verdictLine').textContent = verdictFor(result.score);
    document.getElementById('tipsList').innerHTML = result.tips.map(t=>`<li>${t}</li>`).join('');
    document.getElementById('feedbackBox').style.display = 'block';
    document.getElementById('feedbackBox').scrollIntoView({behavior:'smooth', block:'nearest'});
  });

  document.getElementById('retryBtn').addEventListener('click', ()=>{
    document.getElementById('answerBox').value = '';
    document.getElementById('wordCount').textContent = '0 words';
    document.getElementById('feedbackBox').style.display = 'none';
    resetTimer();
  });

  document.getElementById('nextQBtn').addEventListener('click', nextQuestion);
  document.getElementById('skipBtn').addEventListener('click', nextQuestion);

  function nextQuestion(){
    currentQIndex++;
    if(currentQIndex >= currentQuestionOrder.length){
      showCertificate();
      return;
    }
    loadQuestion();
  }

  document.getElementById('backToCats').addEventListener('click', ()=>{
    clearInterval(timerInterval);
    document.getElementById('practiceStage').style.display = 'none';
    document.getElementById('pickerStage').style.display = 'block';
  });

  function updateStats(){
    document.getElementById('statAttempts').textContent = scores.length;
    document.getElementById('statBest').textContent = scores.length ? Math.max(...scores) : 0;
    document.getElementById('statAvg').textContent = scores.length ? Math.round(scores.reduce((a,b)=>a+b,0)/scores.length) : '–';
  }

  function showCertificate(){
    document.getElementById('practiceStage').style.display = 'none';
    document.getElementById('certWrap').style.display = 'block';
    const avg = scores.length ? Math.round(scores.reduce((a,b)=>a+b,0)/scores.length) : 0;
    document.getElementById('certNote').textContent = `Average confidence score: ${avg}/100 across ${scores.length} question(s) in "${currentCat.name}".`;
    document.getElementById('certDate').textContent = new Date().toLocaleDateString('en-IN', { day:'numeric', month:'long', year:'numeric' });
    document.getElementById('certWrap').scrollIntoView({behavior:'smooth'});
  }

  document.getElementById('downloadCertBtn').addEventListener('click', ()=>{
    const nameInput = prompt("Type your name for the certificate:", "");
    if(nameInput && nameInput.trim()){
      document.getElementById('certName').textContent = nameInput.trim();
    }
    window.print();
  });
  document.getElementById('closeCertBtn').addEventListener('click', ()=>{
    document.getElementById('certWrap').style.display = 'none';
    document.getElementById('pickerStage').style.display = 'block';
  });

  // Web Speech API (optional, Chrome/Edge only)
  const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
  const micBtn = document.getElementById('micBtn');
  if(SpeechRecognition){
    recognition = new SpeechRecognition();
    recognition.lang = 'en-IN';
    recognition.continuous = true;
    recognition.interimResults = true;

    let finalTranscript = '';
    recognition.onresult = (event)=>{
      let interim = '';
      for(let i=event.resultIndex;i<event.results.length;i++){
        if(event.results[i].isFinal){
          finalTranscript += event.results[i][0].transcript + ' ';
        } else {
          interim += event.results[i][0].transcript;
        }
      }
      document.getElementById('answerBox').value = (finalTranscript + interim).trim();
      const words = document.getElementById('answerBox').value.trim().split(/\s+/).filter(Boolean).length;
      document.getElementById('wordCount').textContent = words + ' words';
    };
    recognition.onend = ()=>{
      recognizing = false;
      micBtn.classList.remove('listening');
      micBtn.textContent = '🎙 Speak instead of type';
    };

    micBtn.addEventListener('click', ()=>{
      if(!recognizing){
        ensureTimerStarted();
        finalTranscript = document.getElementById('answerBox').value ? document.getElementById('answerBox').value + ' ' : '';
        recognition.start();
        recognizing = true;
        micBtn.classList.add('listening');
        micBtn.textContent = '⏺ Listening... click to stop';
      } else {
        recognition.stop();
      }
    });
  } else {
    micBtn.addEventListener('click', ()=>{
      alert("Voice input works best in Chrome or Edge on desktop/Android. Type your answer instead — it's scored the same way!");
    });
  }

  const shareUrl = 'https://www.snapskill.in/tools/interview-prep-en';
  const shareText = "Found a free tool that practices interview English with actual feedback, no judgement — SnapSkill's Interview Prep. Try it:";
  document.getElementById('waShareBtn').href = 'https://wa.me/?text=' + encodeURIComponent(shareText + ' ' + shareUrl);
  document.getElementById('copyLinkBtn').addEventListener('click', (e)=>{
    const btn = e.currentTarget;
    const done = ()=>{ const old = btn.textContent; btn.textContent = '✅ Copied!'; setTimeout(()=>{ btn.textContent = old; }, 1800); };
    if(navigator.clipboard && navigator.clipboard.writeText){
      navigator.clipboard.writeText(shareUrl).then(done).catch(()=>{ prompt('Copy this link:', shareUrl); });
    } else {
      prompt('Copy this link:', shareUrl);
    }
  });

  renderCatGrid();
  updateStats();
})();

</script>
