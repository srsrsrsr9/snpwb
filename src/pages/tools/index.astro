---
import BaseLayout from '../../layouts/BaseLayout.astro'
import Nav from '../../components/Nav.astro'
import Footer from '../../components/Footer.astro'

const tools = [
  {
    emoji: '📄',
    title: 'Resume Builder',
    desc: 'Fill a fun, step-by-step form and walk out with a résumé that actually looks like you hired a consultant. Four downloadable layouts to choose from.',
    hinglish: '/tools/resume-builder',
    english: '/tools/resume-builder-en',
  },
  {
    emoji: '🎤',
    title: 'Interview Prep',
    desc: 'Practice real interview questions out loud (or by typing), get instant, honest feedback on filler words, structure, and confidence — plus a certificate at the end.',
    hinglish: '/tools/interview-prep',
    english: '/tools/interview-prep-en',
  },
]
---

<BaseLayout
  title="Free Placement Prep Tools"
  description="Free, fun tools from SnapSkill to help college students prep for placements — a resume builder and an interview confidence coach."
>
  <Nav />
  <main>
    <section class="tools-hero section">
      <div class="container">
        <p class="badge badge--accent">Free tools</p>
        <h1>Placement prep, minus the boredom.</h1>
        <p class="hero-sub">Built for college students gearing up for campus placements — no sign-up, nothing to install, just open and go.</p>
      </div>
    </section>

    <section class="tools-grid-section section">
      <div class="container tools-grid">
        {tools.map((tool) => (
          <div class="tool-card">
            <div class="tool-emoji" aria-hidden="true">{tool.emoji}</div>
            <h2>{tool.title}</h2>
            <p>{tool.desc}</p>
            <div class="tool-links">
              <a class="btn btn--primary" href={tool.hinglish}>Try it (Hinglish)</a>
              <a class="btn btn--outline" href={tool.english}>Try it (English)</a>
            </div>
          </div>
        ))}
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .tools-hero {
    padding: var(--space-xl) 0 var(--space-lg);
    text-align: center;
  }
  .tools-hero h1 {
    margin: var(--space-sm) 0;
    font-size: clamp(2rem, 4.5vw, 3rem);
  }
  .hero-sub {
    max-width: 560px;
    margin: 0 auto;
    color: var(--color-body);
  }

  .tools-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-lg);
  }

  .tool-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
    transition: var(--transition);
  }
  .tool-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }
  .tool-emoji { font-size: 2rem; margin-bottom: var(--space-xs); }
  .tool-card h2 {
    font-size: 1.4rem;
    margin-bottom: var(--space-xs);
  }
  .tool-card p {
    color: var(--color-body);
    margin-bottom: var(--space-md);
  }
  .tool-links {
    display: flex;
    gap: var(--space-xs);
    flex-wrap: wrap;
  }
</style>
