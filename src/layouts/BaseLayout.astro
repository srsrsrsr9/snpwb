---
import '../styles/global.css'

interface Props {
  title: string
  description?: string
  image?: string
}

const {
  title,
  description = 'SnapSkill helps enterprises implement AI that actually works — from strategy through execution.',
  image = '/og-default.png',
} = Astro.props

const canonical = new URL(Astro.url.pathname, Astro.site)
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="canonical" href={canonical} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700;800&family=Inter:wght@400;500;600&family=Space+Mono:ital,wght@0,400;1,400&display=swap"
  />

  <title>{title} | SnapSkill</title>
  <meta name="description" content={description} />

  <meta property="og:title"       content={`${title} | SnapSkill`} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={image} />
  <meta property="og:url"         content={canonical} />
  <meta property="og:type"        content="website" />

  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={`${title} | SnapSkill`} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={image} />
</head>
<body>
  <slot />
</body>
</html>
